+        if not finishing and sp.stop_token_ids and last_token in sp.stop_token_ids:
+            finishing = True
+
+        # max_tokens / max_model_len length cap
+        if not finishing:
+            if sp.max_tokens is not None and len(output_ids) >= sp.max_tokens:
+                finishing = True
