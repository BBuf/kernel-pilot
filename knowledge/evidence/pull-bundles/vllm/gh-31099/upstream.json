      "raw_url": "https://github.com/vllm-project/vllm/raw/a69c99680998210223b7e39e95849533b148a173/vllm%2Fmodel_executor%2Flayers%2Fquantization%2Fcompressed_tensors%2Fschemes%2Fcompressed_tensors_w4a4_nvfp4.py",
