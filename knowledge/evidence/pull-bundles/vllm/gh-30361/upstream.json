    "title": "[Attention][AMD] Make flash-attn optional",
    "user": {
      "login": "mgehre-amd",
      "id": 93204396,
      "node_id": "U_kgDOBY4vrA",
      "avatar_url": "https://avatars.githubusercontent.com/u/93204396?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/mgehre-amd",
      "html_url": "https://github.com/mgehre-amd",
      "followers_url": "https://api.github.com/users/mgehre-amd/followers",
      "following_url": "https://api.github.com/users/mgehre-amd/following{/other_user}",
      "gists_url": "https://api.github.com/users/mgehre-amd/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/mgehre-amd/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/mgehre-amd/subscriptions",
      "organizations_url": "https://api.github.com/users/mgehre-amd/orgs",
      "repos_url": "https://api.github.com/users/mgehre-amd/repos",
      "events_url": "https://api.github.com/users/mgehre-amd/events{/privacy}",
      "received_events_url": "https://api.github.com/users/mgehre-amd/received_events",
