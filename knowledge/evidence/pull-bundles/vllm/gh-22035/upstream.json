    "title": "[Kernels] Clean up FusedMoeMethodBase and modular kernel setup.  Remove extra arguments from modular kernel methods.",
    "user": {
      "login": "bnellnm",
      "id": 49004751,
      "node_id": "MDQ6VXNlcjQ5MDA0NzUx",
      "avatar_url": "https://avatars.githubusercontent.com/u/49004751?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/bnellnm",
      "html_url": "https://github.com/bnellnm",
