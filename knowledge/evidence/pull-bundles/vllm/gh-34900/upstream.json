    "title": "[Model Bash][DSR1] Add selective dynamic shape marking for CustomOp",
    "user": {
      "login": "vadiklyutiy",
      "id": 156319763,
      "node_id": "U_kgDOCVFAEw",
      "avatar_url": "https://avatars.githubusercontent.com/u/156319763?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/vadiklyutiy",
      "html_url": "https://github.com/vadiklyutiy",
      "followers_url": "https://api.github.com/users/vadiklyutiy/followers",
      "following_url": "https://api.github.com/users/vadiklyutiy/following{/other_user}",
      "gists_url": "https://api.github.com/users/vadiklyutiy/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/vadiklyutiy/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/vadiklyutiy/subscriptions",
      "organizations_url": "https://api.github.com/users/vadiklyutiy/orgs",
      "repos_url": "https://api.github.com/users/vadiklyutiy/repos",
      "events_url": "https://api.github.com/users/vadiklyutiy/events{/privacy}",
      "received_events_url": "https://api.github.com/users/vadiklyutiy/received_events",
