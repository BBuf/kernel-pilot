    "title": "[Performance] Reduce DeepGEMM N dim restriction from 128 to 64 multiplier ",
    "user": {
      "login": "alexm-redhat",
      "id": 59768536,
      "node_id": "MDQ6VXNlcjU5NzY4NTM2",
      "avatar_url": "https://avatars.githubusercontent.com/u/59768536?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/alexm-redhat",
      "html_url": "https://github.com/alexm-redhat",
      "followers_url": "https://api.github.com/users/alexm-redhat/followers",
      "following_url": "https://api.github.com/users/alexm-redhat/following{/other_user}",
      "gists_url": "https://api.github.com/users/alexm-redhat/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/alexm-redhat/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/alexm-redhat/subscriptions",
      "organizations_url": "https://api.github.com/users/alexm-redhat/orgs",
      "repos_url": "https://api.github.com/users/alexm-redhat/repos",
      "events_url": "https://api.github.com/users/alexm-redhat/events{/privacy}",
      "received_events_url": "https://api.github.com/users/alexm-redhat/received_events",
