      "additions": 9,
      "deletions": 2,
      "changes": 11,
      "blob_url": "https://github.com/vllm-project/vllm/blob/47abf0e29a1ea4e2b7334cebb3a2f6c4b1176606/vllm%2Futils%2Fdeep_gemm.py",
