    "title": "[Bugfix] Relax TRTLLM KV cache contiguity assertion for cross-layer layout",
    "user": {
      "login": "Etelis",
      "id": 92247226,
      "node_id": "U_kgDOBX-Uug",
      "avatar_url": "https://avatars.githubusercontent.com/u/92247226?v=4",
      "gravatar_id": "",
