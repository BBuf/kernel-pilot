    "title": "[Model Runner V2] fix draft attention metadata generation",
    "user": {
      "login": "TheEpicDolphin",
      "id": 32987265,
      "node_id": "MDQ6VXNlcjMyOTg3MjY1",
      "avatar_url": "https://avatars.githubusercontent.com/u/32987265?v=4",
