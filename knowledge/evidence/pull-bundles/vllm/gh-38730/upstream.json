    "title": "[Bugfix] Restrict TRTLLM attention to SM100, fixing GB300 (SM103) hang",
    "user": {
      "login": "stecasta",
      "id": 46621686,
      "node_id": "MDQ6VXNlcjQ2NjIxNjg2",
      "avatar_url": "https://avatars.githubusercontent.com/u/46621686?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/stecasta",
      "html_url": "https://github.com/stecasta",
      "followers_url": "https://api.github.com/users/stecasta/followers",
      "following_url": "https://api.github.com/users/stecasta/following{/other_user}",
      "gists_url": "https://api.github.com/users/stecasta/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/stecasta/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/stecasta/subscriptions",
      "organizations_url": "https://api.github.com/users/stecasta/orgs",
      "repos_url": "https://api.github.com/users/stecasta/repos",
      "events_url": "https://api.github.com/users/stecasta/events{/privacy}",
