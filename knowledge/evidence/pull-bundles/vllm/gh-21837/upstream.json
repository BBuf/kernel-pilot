    "title": "[Bugfix] [Performance] DeepEPHighThroughput + DeepSeek : Quant before Dispatch",
    "user": {
      "login": "varun-sundar-rabindranath",
      "id": 3337719,
      "node_id": "MDQ6VXNlcjMzMzc3MTk=",
      "avatar_url": "https://avatars.githubusercontent.com/u/3337719?v=4",
      "gravatar_id": "",
