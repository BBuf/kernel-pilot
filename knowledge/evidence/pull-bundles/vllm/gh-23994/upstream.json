    "locked": false,
    "title": "[BUGFIX] GPTQ quantization compatibility for Qwen3 MOE models (AutoGPTQ and AutoRound-GPTQ)",
    "user": {
      "login": "JartX",
      "id": 8399211,
      "node_id": "MDQ6VXNlcjgzOTkyMTE=",
      "avatar_url": "https://avatars.githubusercontent.com/u/8399211?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/JartX",
      "html_url": "https://github.com/JartX",
      "followers_url": "https://api.github.com/users/JartX/followers",
      "following_url": "https://api.github.com/users/JartX/following{/other_user}",
      "gists_url": "https://api.github.com/users/JartX/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/JartX/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/JartX/subscriptions",
      "organizations_url": "https://api.github.com/users/JartX/orgs",
      "repos_url": "https://api.github.com/users/JartX/repos",
      "events_url": "https://api.github.com/users/JartX/events{/privacy}",
