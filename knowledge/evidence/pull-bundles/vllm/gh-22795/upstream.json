      "gists_url": "https://api.github.com/users/JartX/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/JartX/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/JartX/subscriptions",
      "organizations_url": "https://api.github.com/users/JartX/orgs",
      "repos_url": "https://api.github.com/users/JartX/repos",
      "events_url": "https://api.github.com/users/JartX/events{/privacy}",
