    "title": "fix: Add SM120 (RTX Blackwell) support for FlashInfer CUTLASS NVFP4 MoE kernels",
    "user": {
      "login": "renehonig",
      "id": 5851246,
      "node_id": "MDQ6VXNlcjU4NTEyNDY=",
      "avatar_url": "https://avatars.githubusercontent.com/u/5851246?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/renehonig",
