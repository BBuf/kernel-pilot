      "subscriptions_url": "https://api.github.com/users/renehonig/subscriptions",
      "organizations_url": "https://api.github.com/users/renehonig/orgs",
      "repos_url": "https://api.github.com/users/renehonig/repos",
      "events_url": "https://api.github.com/users/renehonig/events{/privacy}",
