    "number": 34673,
    "state": "closed",
    "locked": false,
    "title": "[Bugfix][MoE Kernel] Fix incorrect routing selection for models without expert groups (e.g., MiniMax-M2.1)",
    "user": {
      "login": "wwl2755",
      "id": 23261448,
      "node_id": "MDQ6VXNlcjIzMjYxNDQ4",
      "avatar_url": "https://avatars.githubusercontent.com/u/23261448?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/wwl2755",
      "html_url": "https://github.com/wwl2755",
      "followers_url": "https://api.github.com/users/wwl2755/followers",
      "following_url": "https://api.github.com/users/wwl2755/following{/other_user}",
      "gists_url": "https://api.github.com/users/wwl2755/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/wwl2755/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/wwl2755/subscriptions",
      "organizations_url": "https://api.github.com/users/wwl2755/orgs",
      "repos_url": "https://api.github.com/users/wwl2755/repos",
      "events_url": "https://api.github.com/users/wwl2755/events{/privacy}",
      "received_events_url": "https://api.github.com/users/wwl2755/received_events",
      "type": "User",
