    "title": "[Bug] Batch invariant: Fix flash attn MLA `RuntimeError: scheduler_metadata must have shape (metadata_size)`",
    "user": {
      "login": "yewentao256",
      "id": 44945378,
      "node_id": "MDQ6VXNlcjQ0OTQ1Mzc4",
      "avatar_url": "https://avatars.githubusercontent.com/u/44945378?v=4",
