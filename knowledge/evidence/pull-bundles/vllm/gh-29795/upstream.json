      "starred_url": "https://api.github.com/users/IwakuraRein/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/IwakuraRein/subscriptions",
      "organizations_url": "https://api.github.com/users/IwakuraRein/orgs",
      "repos_url": "https://api.github.com/users/IwakuraRein/repos",
