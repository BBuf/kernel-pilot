    "state": "closed",
    "locked": false,
    "title": "[BugFix][ROCm] Fix GGUF MoE Dispatch Block_Dim for ROCm",
    "user": {
      "login": "tywuAMD",
      "id": 24844634,
      "node_id": "MDQ6VXNlcjI0ODQ0NjM0",
      "avatar_url": "https://avatars.githubusercontent.com/u/24844634?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/tywuAMD",
      "html_url": "https://github.com/tywuAMD",
      "followers_url": "https://api.github.com/users/tywuAMD/followers",
      "following_url": "https://api.github.com/users/tywuAMD/following{/other_user}",
      "gists_url": "https://api.github.com/users/tywuAMD/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/tywuAMD/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/tywuAMD/subscriptions",
      "organizations_url": "https://api.github.com/users/tywuAMD/orgs",
      "repos_url": "https://api.github.com/users/tywuAMD/repos",
      "events_url": "https://api.github.com/users/tywuAMD/events{/privacy}",
