    "number": 35850,
    "state": "closed",
    "locked": false,
    "title": "[ROCm] Support MLA with nhead<16 and FP8 KV cache for TP=8 (Kimi K2.5/Linear)",
    "user": {
      "login": "ChuanLi1101",
      "id": 245976303,
      "node_id": "U_kgDODqlM7w",
      "avatar_url": "https://avatars.githubusercontent.com/u/245976303?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/ChuanLi1101",
      "html_url": "https://github.com/ChuanLi1101",
      "followers_url": "https://api.github.com/users/ChuanLi1101/followers",
      "following_url": "https://api.github.com/users/ChuanLi1101/following{/other_user}",
      "gists_url": "https://api.github.com/users/ChuanLi1101/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/ChuanLi1101/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/ChuanLi1101/subscriptions",
      "organizations_url": "https://api.github.com/users/ChuanLi1101/orgs",
