      "blob_url": "https://github.com/vllm-project/vllm/blob/92caef070db8fc1fb5a1de052db39a57f26c146a/vllm%2Fmodel_executor%2Flayers%2Ffused_moe%2Fexperts%2Ftrtllm_fp8_moe.py",
      "raw_url": "https://github.com/vllm-project/vllm/raw/92caef070db8fc1fb5a1de052db39a57f26c146a/vllm%2Fmodel_executor%2Flayers%2Ffused_moe%2Fexperts%2Ftrtllm_fp8_moe.py",
      "contents_url": "https://api.github.com/repos/vllm-project/vllm/contents/vllm%2Fmodel_executor%2Flayers%2Ffused_moe%2Fexperts%2Ftrtllm_fp8_moe.py?ref=92caef070db8fc1fb5a1de052db39a57f26c146a",
      "patch": "@@ -269,26 +269,29 @@ def _supports_routing_method(\n         weight_key: QuantKey | None,\n         activation_key: QuantKey | None,\n     ) -> bool:\n-        \"\"\"Monolithic kernels need to express router support.\"\"\"\n+        \"\"\"Monolithic kernels need to express router support.\n+        Renormalize/RenormalizeNaive are excluded: the monolithic kernel's\n+        internal routing for these methods produces output uncorrelated\n+        with the modular kernel's output and with Triton kernel's output\n+        for Qwen3.5-35B-A3B-FP8.\n+        See: https://github.com/vllm-project/vllm/issues/37591\n+        \"\"\"\n         # NOTE(dbari): TopK routing could also be enabled, but need to validate models\n         # NOTE(dbari): Default is not implemented and should not be enabled until it is\n+\n         if (weight_key, activation_key) in [\n             (kFp8Static128BlockSym, kFp8Dynamic128Sym),\n             (kMxfp8Static, kMxfp8Dynamic),\n         ]:\n             # NOTE(rob): potentially allow others here. This is a conservative list.\n             return routing_method in [\n                 RoutingMethodType.DeepSeekV3,\n-                RoutingMethodType.Renormalize,\n-                RoutingMethodType.RenormalizeNaive,\n             ]\n         elif (weight_key, activation_key) == (kFp8StaticTensorSym, kFp8StaticTensorSym):\n             # NOTE(dbari): as above, potentially allow others here.\n             return routing_method in [\n                 RoutingMethodType.DeepSeekV3,\n                 RoutingMethodType.Llama4,\n-                RoutingMethodType.Renormalize,\n-                RoutingMethodType.RenormalizeNaive,\n             ]\n         else:\n             raise ValueError(\"Unsupported quantization scheme.\")"
    }
