      "followers_url": "https://api.github.com/users/yewentao256/followers",
      "following_url": "https://api.github.com/users/yewentao256/following{/other_user}",
      "gists_url": "https://api.github.com/users/yewentao256/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/yewentao256/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/yewentao256/subscriptions",
      "organizations_url": "https://api.github.com/users/yewentao256/orgs",
      "repos_url": "https://api.github.com/users/yewentao256/repos",
