    "title": "[Bugfix] Fix gpt-oss w4a8 DP/EP on B200",
    "user": {
      "login": "varun-sundar-rabindranath",
      "id": 3337719,
      "node_id": "MDQ6VXNlcjMzMzc3MTk=",
      "avatar_url": "https://avatars.githubusercontent.com/u/3337719?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/varun-sundar-rabindranath",
