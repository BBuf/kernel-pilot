      "followers_url": "https://api.github.com/users/varun-sundar-rabindranath/followers",
      "following_url": "https://api.github.com/users/varun-sundar-rabindranath/following{/other_user}",
      "gists_url": "https://api.github.com/users/varun-sundar-rabindranath/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/varun-sundar-rabindranath/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/varun-sundar-rabindranath/subscriptions",
      "organizations_url": "https://api.github.com/users/varun-sundar-rabindranath/orgs",
      "repos_url": "https://api.github.com/users/varun-sundar-rabindranath/repos",
      "events_url": "https://api.github.com/users/varun-sundar-rabindranath/events{/privacy}",
