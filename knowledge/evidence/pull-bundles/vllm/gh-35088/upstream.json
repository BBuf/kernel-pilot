    "title": "Fix fallback to default tactic (flashinfer autotuner) with trtllm_fp4_block_scale_moe",
    "user": {
      "login": "danisereb",
      "id": 249064951,
      "node_id": "U_kgDODtht9w",
      "avatar_url": "https://avatars.githubusercontent.com/u/249064951?v=4",
      "gravatar_id": "",
