        apply_router_weight_on_input=True,\n@@ -253,7 +261,7 @@ def get_fused_moe_quant_config(n: torch.nn.Module) -> FusedMoEQuantConfig:\n             td.layer,\n             topk_weights,\n             topk_ids,\n-            activation=\"silu\",\n+            activation=activation,\n             global_num_experts=e,\n             expert_map=None,\n             apply_router_weight_on_input=True,"
