    "title": "Fix AWQ MoE marlin check issue in marlin_utils.py for AMD backend",
    "user": {
      "login": "yuttian1",
      "id": 224218912,
      "node_id": "U_kgDODV1PIA",
      "avatar_url": "https://avatars.githubusercontent.com/u/224218912?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/yuttian1",
