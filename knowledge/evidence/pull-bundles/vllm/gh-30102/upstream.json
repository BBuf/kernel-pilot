      "followers_url": "https://api.github.com/users/yuttian1/followers",
      "following_url": "https://api.github.com/users/yuttian1/following{/other_user}",
      "gists_url": "https://api.github.com/users/yuttian1/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/yuttian1/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/yuttian1/subscriptions",
      "organizations_url": "https://api.github.com/users/yuttian1/orgs",
      "repos_url": "https://api.github.com/users/yuttian1/repos",
