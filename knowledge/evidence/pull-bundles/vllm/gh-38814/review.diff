+    _fa_mod.__package__ = "flash_attn"
+    _fa_mod.__spec__ = importlib.machinery.ModuleSpec(
+        "flash_attn", None, is_package=True
+    )
+    _fa_mod.__spec__.submodule_search_locations = _fa_mod.__path__
+    sys.modules["flash_attn"] = _fa_mod
