    "title": "[FlashAttention] Symlink FA4 instead of copying when using `VLLM_FLASH_ATTN_SRC_DIR`",
    "user": {
      "login": "MatthewBonanni",
      "id": 22648877,
      "node_id": "MDQ6VXNlcjIyNjQ4ODc3",
      "avatar_url": "https://avatars.githubusercontent.com/u/22648877?v=4",
