    "title": "[XPU] properly handle q_descale on XPU as quant query input not supported",
    "user": {
      "login": "yma11",
      "id": 11849056,
      "node_id": "MDQ6VXNlcjExODQ5MDU2",
      "avatar_url": "https://avatars.githubusercontent.com/u/11849056?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/yma11",
      "html_url": "https://github.com/yma11",
      "followers_url": "https://api.github.com/users/yma11/followers",
      "following_url": "https://api.github.com/users/yma11/following{/other_user}",
      "gists_url": "https://api.github.com/users/yma11/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/yma11/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/yma11/subscriptions",
      "organizations_url": "https://api.github.com/users/yma11/orgs",
      "repos_url": "https://api.github.com/users/yma11/repos",
      "events_url": "https://api.github.com/users/yma11/events{/privacy}",
