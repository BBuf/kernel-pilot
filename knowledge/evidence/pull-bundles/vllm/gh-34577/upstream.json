    "title": "[Bugfix] Rescale NVFP4 weight scales to fix BF16 dequant underflow",
    "user": {
      "login": "ricky-chaoju",
      "id": 109416633,
      "node_id": "U_kgDOBoWQuQ",
      "avatar_url": "https://avatars.githubusercontent.com/u/109416633?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/ricky-chaoju",
      "html_url": "https://github.com/ricky-chaoju",
      "followers_url": "https://api.github.com/users/ricky-chaoju/followers",
      "following_url": "https://api.github.com/users/ricky-chaoju/following{/other_user}",
