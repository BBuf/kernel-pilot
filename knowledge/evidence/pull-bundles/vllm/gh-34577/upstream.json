      "starred_url": "https://api.github.com/users/ricky-chaoju/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/ricky-chaoju/subscriptions",
      "organizations_url": "https://api.github.com/users/ricky-chaoju/orgs",
      "repos_url": "https://api.github.com/users/ricky-chaoju/repos",
      "events_url": "https://api.github.com/users/ricky-chaoju/events{/privacy}",
      "received_events_url": "https://api.github.com/users/ricky-chaoju/received_events",
