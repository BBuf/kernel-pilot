      "blob_url": "https://github.com/vllm-project/vllm/blob/6f71fa9131ec2d357d726fcee8584948f8f06ae3/vllm%2Fmodel_executor%2Flayers%2Fquantization%2Futils%2Fmarlin_utils_fp4.py",
