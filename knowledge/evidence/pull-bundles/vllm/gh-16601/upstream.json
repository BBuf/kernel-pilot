    "title": "[Bugfix] Move current_platform import to avoid python import cache.",
    "user": {
      "login": "iwzbi",
      "id": 108673086,
      "node_id": "U_kgDOBno4Pg",
      "avatar_url": "https://avatars.githubusercontent.com/u/108673086?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/iwzbi",
      "html_url": "https://github.com/iwzbi",
      "followers_url": "https://api.github.com/users/iwzbi/followers",
      "following_url": "https://api.github.com/users/iwzbi/following{/other_user}",
      "gists_url": "https://api.github.com/users/iwzbi/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/iwzbi/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/iwzbi/subscriptions",
      "organizations_url": "https://api.github.com/users/iwzbi/orgs",
      "repos_url": "https://api.github.com/users/iwzbi/repos",
      "events_url": "https://api.github.com/users/iwzbi/events{/privacy}",
