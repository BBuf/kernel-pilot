      "subscriptions_url": "https://api.github.com/users/jinzhen-lin/subscriptions",
      "organizations_url": "https://api.github.com/users/jinzhen-lin/orgs",
      "repos_url": "https://api.github.com/users/jinzhen-lin/repos",
      "events_url": "https://api.github.com/users/jinzhen-lin/events{/privacy}",
