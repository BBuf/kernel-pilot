    "title": "Fix INT8 quantization error on Blackwell GPUs (SM100+)",
    "user": {
      "login": "certainly-param",
      "id": 206301545,
      "node_id": "U_kgDODEvpaQ",
      "avatar_url": "https://avatars.githubusercontent.com/u/206301545?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/certainly-param",
      "html_url": "https://github.com/certainly-param",
      "followers_url": "https://api.github.com/users/certainly-param/followers",
      "following_url": "https://api.github.com/users/certainly-param/following{/other_user}",
