    "number": 19346,
    "state": "closed",
    "locked": false,
    "title": "[Kernel] Apply torch.Tag.needs_fixed_stride_order only for torch==2.6.0",
    "user": {
      "login": "zou3519",
      "id": 5652049,
      "node_id": "MDQ6VXNlcjU2NTIwNDk=",
      "avatar_url": "https://avatars.githubusercontent.com/u/5652049?v=4",
      "gravatar_id": "",
