      "deletions": 7,
      "changes": 18,
      "blob_url": "https://github.com/vllm-project/vllm/blob/6c2e41d227a29cdaa3ae5b5f92a8c1b9169fc29e/vllm%2Fmodel_executor%2Flayers%2Ffused_moe%2Flayer.py",
