    "number": 18093,
    "state": "closed",
    "locked": false,
    "title": "[Bugfix][ROCm] Use `chunked_prefill_paged_decode` as fallback for V1 attention on ROCm",
    "user": {
      "login": "kliuae",
      "id": 17350011,
      "node_id": "MDQ6VXNlcjE3MzUwMDEx",
      "avatar_url": "https://avatars.githubusercontent.com/u/17350011?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/kliuae",
      "html_url": "https://github.com/kliuae",
      "followers_url": "https://api.github.com/users/kliuae/followers",
      "following_url": "https://api.github.com/users/kliuae/following{/other_user}",
      "gists_url": "https://api.github.com/users/kliuae/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/kliuae/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/kliuae/subscriptions",
      "organizations_url": "https://api.github.com/users/kliuae/orgs",
      "repos_url": "https://api.github.com/users/kliuae/repos",
      "events_url": "https://api.github.com/users/kliuae/events{/privacy}",
