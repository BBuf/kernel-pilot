      "status": "modified",
      "additions": 18,
      "deletions": 0,
      "changes": 18,
      "blob_url": "https://github.com/vllm-project/vllm/blob/0d40cafd88c4e96ae35f038d5d6b41c0df59e47f/tests%2Fkernels%2Fmoe%2Ftest_moe.py",
