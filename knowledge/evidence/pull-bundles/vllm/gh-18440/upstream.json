      "contents_url": "https://api.github.com/repos/vllm-project/vllm/contents/tests%2Fkernels%2Fmoe%2Ftest_moe.py?ref=0d40cafd88c4e96ae35f038d5d6b41c0df59e47f",
      "patch": "@@ -575,3 +575,21 @@ def test_moe_align_block_size_opcheck():\n     opcheck(torch.ops._moe_C.moe_align_block_size,\n             (topk_ids, num_experts, block_size, sorted_ids, expert_ids,\n              num_tokens_post_pad))\n+\n+\n+@pytest.mark.parametrize(\"m\", [1, 33, 222, 1024 * 128])\n+@pytest.mark.parametrize(\"topk\", TOP_KS)\n+@pytest.mark.parametrize(\"k\", [128, 511, 1024])\n+@pytest.mark.parametrize(\"dtype\",\n+                         [torch.float32, torch.float16, torch.bfloat16])\n+@pytest.mark.skipif(current_platform.is_rocm(), reason=\"Skip for rocm\")\n+def test_moe_sum(m: int, topk: int, k: int, dtype: torch.dtype):\n+    input = torch.randn((m, topk, k), device=\"cuda\", dtype=dtype)\n+    actual = torch.empty((m, k), device=\"cuda\", dtype=dtype)\n+\n+    expected = input.sum(dim=1)\n+    torch.ops._moe_C.moe_sum(input, actual)\n+\n+    torch.testing.assert_close(actual, expected, atol=2e-2, rtol=0)\n+\n+    opcheck(torch.ops._moe_C.moe_sum, (input, actual))"
    }
