      "patch": "@@ -125,7 +125,9 @@ def process_weights_after_loading(self, layer: torch.nn.Module) -> None:\n \n         # These are used in the final Attention.forward()\n         layer._q_scale.copy_(q_scale)\n-        layer._q_scale_float = q_scale\n+        layer._q_scale_float = q_scale.item() if isinstance(\n+            q_scale, torch.Tensor) else q_scale\n+\n         layer._prob_scale.copy_(prob_scale)\n         if layer.kv_cache_dtype == \"fp8\" and (q_scale == 1.0\n                                               or prob_scale == 1.0):"
    },
    {
      "sha": "784912a122f681d561cede6bd3d8ffde4af05ce0",
      "filename": "vllm/v1/attention/backends/triton_attn.py",
      "status": "modified",
      "additions": 1,
      "deletions": 1,
