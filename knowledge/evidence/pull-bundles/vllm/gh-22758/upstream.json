      "additions": 3,
      "deletions": 1,
      "changes": 4,
      "blob_url": "https://github.com/vllm-project/vllm/blob/bb5b6721cf7811b9df4fc07a4ec44a8840b19003/vllm%2Fmodel_executor%2Flayers%2Fquantization%2Fkv_cache.py",
