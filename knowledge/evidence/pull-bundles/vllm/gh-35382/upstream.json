    "title": "fix(mxfp4): return is_monolithic=False when LoRA is enabled for Triton backend",
    "user": {
      "login": "yoonsnowdev",
      "id": 212460519,
      "node_id": "U_kgDODKnj5w",
      "avatar_url": "https://avatars.githubusercontent.com/u/212460519?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/yoonsnowdev",
      "html_url": "https://github.com/yoonsnowdev",
      "followers_url": "https://api.github.com/users/yoonsnowdev/followers",
      "following_url": "https://api.github.com/users/yoonsnowdev/following{/other_user}",
      "gists_url": "https://api.github.com/users/yoonsnowdev/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/yoonsnowdev/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/yoonsnowdev/subscriptions",
      "organizations_url": "https://api.github.com/users/yoonsnowdev/orgs",
      "repos_url": "https://api.github.com/users/yoonsnowdev/repos",
      "events_url": "https://api.github.com/users/yoonsnowdev/events{/privacy}",
      "received_events_url": "https://api.github.com/users/yoonsnowdev/received_events",
      "type": "User",
