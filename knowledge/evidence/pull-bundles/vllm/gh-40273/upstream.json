      "changes": 5,
      "blob_url": "https://github.com/vllm-project/vllm/blob/8012f929edfb844d7d67c9d6ddf3a870f8a2aed4/vllm%2Fmodel_executor%2Flayers%2Ffused_moe%2Foracle%2Funquantized.py",
      "raw_url": "https://github.com/vllm-project/vllm/raw/8012f929edfb844d7d67c9d6ddf3a870f8a2aed4/vllm%2Fmodel_executor%2Flayers%2Ffused_moe%2Foracle%2Funquantized.py",
      "contents_url": "https://api.github.com/repos/vllm-project/vllm/contents/vllm%2Fmodel_executor%2Flayers%2Ffused_moe%2Foracle%2Funquantized.py?ref=8012f929edfb844d7d67c9d6ddf3a870f8a2aed4",
      "patch": "@@ -163,6 +163,11 @@ def select_unquantized_moe_backend(\n     if current_platform.is_out_of_tree():\n         return UnquantizedMoeBackend.OOT, None\n \n+    if moe_config.is_lora_enabled:\n+        return UnquantizedMoeBackend.TRITON, backend_to_kernel_cls(\n+            UnquantizedMoeBackend.TRITON\n+        )\n+\n     # NOTE: the kernels are selected in the following order.\n     AVAILABLE_BACKENDS = _get_priority_backends(moe_config)\n "
    }
