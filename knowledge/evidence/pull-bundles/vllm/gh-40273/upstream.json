    "title": "Fix MoE backend selection for LoRA (unquantized MoE)",
    "user": {
      "login": "danisereb",
      "id": 249064951,
      "node_id": "U_kgDODtht9w",
      "avatar_url": "https://avatars.githubusercontent.com/u/249064951?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/danisereb",
      "html_url": "https://github.com/danisereb",
      "followers_url": "https://api.github.com/users/danisereb/followers",
      "following_url": "https://api.github.com/users/danisereb/following{/other_user}",
      "gists_url": "https://api.github.com/users/danisereb/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/danisereb/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/danisereb/subscriptions",
      "organizations_url": "https://api.github.com/users/danisereb/orgs",
      "repos_url": "https://api.github.com/users/danisereb/repos",
      "events_url": "https://api.github.com/users/danisereb/events{/privacy}",
