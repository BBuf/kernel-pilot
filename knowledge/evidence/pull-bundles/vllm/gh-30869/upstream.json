    "locked": false,
    "title": "[Bugfix] fix the alias bug of AttentionBackendEnum when register CUSTOM attention backend to vllm",
    "user": {
      "login": "zejunchen-zejun",
      "id": 220282114,
      "node_id": "U_kgDODSE9Ag",
      "avatar_url": "https://avatars.githubusercontent.com/u/220282114?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/zejunchen-zejun",
      "html_url": "https://github.com/zejunchen-zejun",
      "followers_url": "https://api.github.com/users/zejunchen-zejun/followers",
      "following_url": "https://api.github.com/users/zejunchen-zejun/following{/other_user}",
      "gists_url": "https://api.github.com/users/zejunchen-zejun/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/zejunchen-zejun/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/zejunchen-zejun/subscriptions",
      "organizations_url": "https://api.github.com/users/zejunchen-zejun/orgs",
      "repos_url": "https://api.github.com/users/zejunchen-zejun/repos",
      "events_url": "https://api.github.com/users/zejunchen-zejun/events{/privacy}",
      "received_events_url": "https://api.github.com/users/zejunchen-zejun/received_events",
