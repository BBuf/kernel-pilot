    "title": "[Bugfix] Handle num_expert_group=None in flashinfer block-scale FP8 MoE",
    "user": {
      "login": "haosdent",
      "id": 950759,
      "node_id": "MDQ6VXNlcjk1MDc1OQ==",
      "avatar_url": "https://avatars.githubusercontent.com/u/950759?v=4",
