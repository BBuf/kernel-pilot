+        w13: [E, 2*N, K] float8_e4m3fn weights.
+        w2:  [E, K, N] float8_e4m3fn weights.
+        w13_scale: [E, 2*N, K//32] uint8 e8m0 scales.
+        w2_scale:  [E, K, N//32] uint8 e8m0 scales.
+
