      "subscriptions_url": "https://api.github.com/users/tlrmchlsmth/subscriptions",
      "organizations_url": "https://api.github.com/users/tlrmchlsmth/orgs",
      "repos_url": "https://api.github.com/users/tlrmchlsmth/repos",
