+    const auto& sum_mk = a.first.numel();
+    const auto& sum_nk = b.first.numel();
+    int sum_k = 0;
+    for (const auto& k: ks)
+        sum_k += k;
+    DG_HOST_ASSERT(sum_mk == m * sum_k);
+    DG_HOST_ASSERT(sum_nk == n * sum_k);
+
+    // Contiguity checks
+    DG_HOST_ASSERT(a.first.is_contiguous());
+    DG_HOST_ASSERT(b.first.is_contiguous());
