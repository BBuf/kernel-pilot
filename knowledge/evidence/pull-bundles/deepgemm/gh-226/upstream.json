      "followers_url": "https://api.github.com/users/SolenoidWGT/followers",
      "following_url": "https://api.github.com/users/SolenoidWGT/following{/other_user}",
      "gists_url": "https://api.github.com/users/SolenoidWGT/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/SolenoidWGT/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/SolenoidWGT/subscriptions",
      "organizations_url": "https://api.github.com/users/SolenoidWGT/orgs",
      "repos_url": "https://api.github.com/users/SolenoidWGT/repos",
