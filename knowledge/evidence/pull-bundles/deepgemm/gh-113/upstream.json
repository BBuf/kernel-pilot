    "title": "Fix illegal memory address when skipping -1 m indices",
    "user": {
      "login": "shixianc",
      "id": 49539556,
      "node_id": "MDQ6VXNlcjQ5NTM5NTU2",
      "avatar_url": "https://avatars.githubusercontent.com/u/49539556?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/shixianc",
      "html_url": "https://github.com/shixianc",
      "followers_url": "https://api.github.com/users/shixianc/followers",
      "following_url": "https://api.github.com/users/shixianc/following{/other_user}",
      "gists_url": "https://api.github.com/users/shixianc/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/shixianc/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/shixianc/subscriptions",
      "organizations_url": "https://api.github.com/users/shixianc/orgs",
      "repos_url": "https://api.github.com/users/shixianc/repos",
      "events_url": "https://api.github.com/users/shixianc/events{/privacy}",
      "received_events_url": "https://api.github.com/users/shixianc/received_events",
      "type": "User",
