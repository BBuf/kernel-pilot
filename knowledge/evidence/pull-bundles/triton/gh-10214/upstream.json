    "title": "Allow MXFP8 LHS with Hopper-swizzled MXFP4 RHS",
    "user": {
      "login": "roman-openai",
      "id": 170452805,
      "node_id": "U_kgDOCijnRQ",
      "avatar_url": "https://avatars.githubusercontent.com/u/170452805?v=4",
