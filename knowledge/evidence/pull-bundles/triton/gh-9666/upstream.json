    "title": "[AMD] Enable loop unrolling for Gluon warp-pipelined kernels",
    "user": {
      "login": "Hardcode84",
      "id": 3274859,
      "node_id": "MDQ6VXNlcjMyNzQ4NTk=",
      "avatar_url": "https://avatars.githubusercontent.com/u/3274859?v=4",
      "gravatar_id": "",
