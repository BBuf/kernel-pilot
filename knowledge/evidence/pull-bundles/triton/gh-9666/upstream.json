      "subscriptions_url": "https://api.github.com/users/Hardcode84/subscriptions",
      "organizations_url": "https://api.github.com/users/Hardcode84/orgs",
      "repos_url": "https://api.github.com/users/Hardcode84/repos",
      "events_url": "https://api.github.com/users/Hardcode84/events{/privacy}",
