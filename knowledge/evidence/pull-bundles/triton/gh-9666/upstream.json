      "html_url": "https://github.com/Hardcode84",
      "followers_url": "https://api.github.com/users/Hardcode84/followers",
      "following_url": "https://api.github.com/users/Hardcode84/following{/other_user}",
      "gists_url": "https://api.github.com/users/Hardcode84/gists{/gist_id}",
