    "title": "[runtime] Skip None args in autotune restore_value/reset_to_zero hooks",
    "user": {
      "login": "kasper0406",
      "id": 1927086,
      "node_id": "MDQ6VXNlcjE5MjcwODY=",
      "avatar_url": "https://avatars.githubusercontent.com/u/1927086?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/kasper0406",
      "html_url": "https://github.com/kasper0406",
      "followers_url": "https://api.github.com/users/kasper0406/followers",
      "following_url": "https://api.github.com/users/kasper0406/following{/other_user}",
      "gists_url": "https://api.github.com/users/kasper0406/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/kasper0406/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/kasper0406/subscriptions",
      "organizations_url": "https://api.github.com/users/kasper0406/orgs",
      "repos_url": "https://api.github.com/users/kasper0406/repos",
      "events_url": "https://api.github.com/users/kasper0406/events{/privacy}",
      "received_events_url": "https://api.github.com/users/kasper0406/received_events",
      "type": "User",
