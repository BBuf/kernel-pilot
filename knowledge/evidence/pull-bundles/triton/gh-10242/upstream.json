    "title": "Fix convert_layout lowering for CGA + slice layouts.",
    "user": {
      "login": "meinie0826",
      "id": 72198170,
      "node_id": "MDQ6VXNlcjcyMTk4MTcw",
      "avatar_url": "https://avatars.githubusercontent.com/u/72198170?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/meinie0826",
      "html_url": "https://github.com/meinie0826",
      "followers_url": "https://api.github.com/users/meinie0826/followers",
      "following_url": "https://api.github.com/users/meinie0826/following{/other_user}",
      "gists_url": "https://api.github.com/users/meinie0826/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/meinie0826/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/meinie0826/subscriptions",
      "organizations_url": "https://api.github.com/users/meinie0826/orgs",
      "repos_url": "https://api.github.com/users/meinie0826/repos",
      "events_url": "https://api.github.com/users/meinie0826/events{/privacy}",
