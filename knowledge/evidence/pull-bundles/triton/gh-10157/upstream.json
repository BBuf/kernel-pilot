    "number": 10157,
    "state": "closed",
    "locked": false,
    "title": "[AMD] Add Triton-level tt.descriptor_gather and tt.descriptor_scatter support for gfx1250",
    "user": {
      "login": "jerryyin",
      "id": 3454501,
      "node_id": "MDQ6VXNlcjM0NTQ1MDE=",
      "avatar_url": "https://avatars.githubusercontent.com/u/3454501?v=4",
