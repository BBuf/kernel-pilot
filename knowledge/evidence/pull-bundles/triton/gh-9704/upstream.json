      "starred_url": "https://api.github.com/users/ZelboK/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/ZelboK/subscriptions",
      "organizations_url": "https://api.github.com/users/ZelboK/orgs",
      "repos_url": "https://api.github.com/users/ZelboK/repos",
      "events_url": "https://api.github.com/users/ZelboK/events{/privacy}",
      "received_events_url": "https://api.github.com/users/ZelboK/received_events",
