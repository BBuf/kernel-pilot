    "title": "[Language] Add field inheritance, defaults, and aggregate_replace to @aggregate",
    "user": {
      "login": "blake-snc",
      "id": 260497114,
      "node_id": "U_kgDOD4be2g",
      "avatar_url": "https://avatars.githubusercontent.com/u/260497114?v=4",
