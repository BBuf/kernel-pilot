    "title": "Fix nested `def` in `@triton.jit` to raise intended `UnsupportedLanguageConstruct`",
    "user": {
      "login": "swjng",
      "id": 48044640,
      "node_id": "MDQ6VXNlcjQ4MDQ0NjQw",
