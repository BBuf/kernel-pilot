    "title": "Fixing splitClusterBefore implicit-insert bug",
    "user": {
      "login": "mydatascience",
      "id": 3028020,
      "node_id": "MDQ6VXNlcjMwMjgwMjA=",
      "avatar_url": "https://avatars.githubusercontent.com/u/3028020?v=4",
      "gravatar_id": "",
