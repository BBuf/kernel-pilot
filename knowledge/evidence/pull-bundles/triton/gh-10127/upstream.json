      "gists_url": "https://api.github.com/users/mydatascience/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/mydatascience/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/mydatascience/subscriptions",
      "organizations_url": "https://api.github.com/users/mydatascience/orgs",
      "repos_url": "https://api.github.com/users/mydatascience/repos",
