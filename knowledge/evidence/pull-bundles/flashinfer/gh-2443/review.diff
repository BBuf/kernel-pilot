+    # Compute inverse scale and convert to E2M1 packed format
+    inv_scale = ue8m0_to_inv_scale_fast(scale_ue8m0_u32)
+    packed64_0, packed64_1 = bfloat2x16_to_e2m1x32_packed(
+        h0,
+        h1,
+        h2,
+        h3,
+        h4,
+        h5,
+        h6,
+        h7,
+        h8,
+        h9,
+        h10,
+        h11,
+        h12,
+        h13,
+        h14,
