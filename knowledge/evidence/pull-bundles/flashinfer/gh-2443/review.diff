+    )  # select any cuda device to get a compute capability
+    device_arch = f"{major * 10 + minor}"
+    return get_fp4_quantization_module(
+        device_arch
+    ).e2m1_and_ufp8sf_scale_to_float_sm100(
+        e2m1_tensor,
+        ufp8_scale_tensor,
