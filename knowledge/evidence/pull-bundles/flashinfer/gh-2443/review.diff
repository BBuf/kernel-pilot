+                Uint32(bf2).ir_value(loc=loc, ip=ip),
+                Float32(inv_scale).ir_value(loc=loc, ip=ip),
+            ],
+            """
+            {
+                .reg .b32 lo, hi;
+                .reg .f32 f0, f1;
+                .reg .b16 fp8_pair;
+
+                and.b32 lo, $1, 0xFFFF;
+                shr.b32 hi, $1, 16;
+                shl.b32 lo, lo, 16;
+                shl.b32 hi, hi, 16;
+                mov.b32 f0, lo;
+                mov.b32 f1, hi;
+                mul.f32 f0, f0, $2;
+                mul.f32 f1, f1, $2;
+                cvt.rn.satfinite.e4m3x2.f32 fp8_pair, f1, f0;
+                cvt.u32.u16 $0, fp8_pair;
+            }
+            """,
+            "=r,r,f",
+            has_side_effects=False,
