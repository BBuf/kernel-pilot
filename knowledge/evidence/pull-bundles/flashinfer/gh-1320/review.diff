+    if (notSupported) {
+      TLLM_LOG_WARNING("Size K / splitK must be a multiple of TileK * 2. Found TileK=",
+                       options.mTileK, " and K=", options.mK, " (paddedK=", paddedK,
+                       ") and numSlicesForSplitK=", options.mNumSlicesForSplitK,
+                       ". Disabling unrollLoop2xForMma.");
