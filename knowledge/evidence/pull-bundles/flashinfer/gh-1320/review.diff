+template <typename T>
+inline T divUp(T a, T b) {
+  return (a + b - 1) / b;
+}
+
+////////////////////////////////////////////////////////////////////////////////////////////////////
+
+template <typename T>
+inline T divUpMul(T a, T b) {
+  return gemm::divUp(a, b) * b;
+}
