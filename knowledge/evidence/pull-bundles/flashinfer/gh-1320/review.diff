+////////////////////////////////////////////////////////////////////////////////////////////////////
+
+template <typename T>
+inline T ceilDiv(T m, T n) {
+  return (m + n - T(1)) / n;
+}
+
+////////////////////////////////////////////////////////////////////////////////////////////////////
+
+template <typename T>
+inline T roundUp(T m, T n) {
+  return ceilDiv(m, n) * n;
+}
+
