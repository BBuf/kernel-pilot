+        return false;                                                                    \
+    }                                                                                    \
+  }()
+
+#define _DISPATCH_CASE_I32(c_type, ...) \
+  case int32_code: {                    \
+    using c_type = int32_t;             \
+    return __VA_ARGS__();               \
+  }
+
+#define _DISPATCH_CASE_I64(c_type, ...) \
+  case int64_code: {                    \
+    using c_type = int64_t;             \
+    return __VA_ARGS__();               \
+  }
