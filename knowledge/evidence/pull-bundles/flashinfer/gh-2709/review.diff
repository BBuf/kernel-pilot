+                intra2_q_pipeline.producer_acquire(intra2_q_producer_state)
+
+                # Store Q from reg to tmem
+                q_coord = (None, None, None, None, intra2_q_producer_state.index)
+                cute.copy(tiled_r2t_q, tRT_rQ, tRT_tQ[q_coord])
