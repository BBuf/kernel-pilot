+            tiled_mma_intra1,
+            self.tile_shape_mnk_intra1,
+            tmem_ptr_base + self.tmem_intra1_acc_offset,
+            self.intra1_acc_stages,
+        )
+        # (M_PER_MMA, N_PER_MMA, INTRA1_ACC_STAGE)
+        tIntra1 = tCtAccIntra1[((None, None), 0, 0, None)]
+
