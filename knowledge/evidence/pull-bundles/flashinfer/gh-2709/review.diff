+        d_linear_smem_layout: Optional[cute.Layout],
+        epi_tile: cute.Tile,
+        tile_sched_params: Mamba2SSDTileSchedulerParams,
+    ):
+        warp_idx = cute.arch.make_warp_uniform(cute.arch.warp_idx())
+
+        # Prefetch tma descriptor
+        if warp_idx == 0:
+            tma_atoms = [
+                tma_atom_x,
+                tma_atom_b,
+                tma_atom_c,
+                tma_atom_p,
+                tma_atom_y,
