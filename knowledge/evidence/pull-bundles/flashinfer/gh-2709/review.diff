+    @cute.jit
+    def _warp_pre_intra(
+        self,
+        local_tidx,
+        smem_cumsum_delta,
+        smem_delta,
+        tmem_ptr_base,
+        tiled_mma_intra1,
+        tiled_mma_intra2,
+        q_tmem_layout,
+        deltas_pipeline,
+        intra1_acc_pipeline,
