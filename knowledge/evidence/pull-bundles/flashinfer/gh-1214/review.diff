-      params.mPtrExpandedIdxToPermutedIdx[expandedIdx] = permutedIdx;
-    }
-    if (params.mPtrPermutedIdxToTokenIdx != nullptr && isLocalExpert) {
-      params.mPtrPermutedIdxToTokenIdx[permutedIdx] = tokenIdx;
-    }
-  }
-}
