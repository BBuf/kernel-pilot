      "following_url": "https://api.github.com/users/alibaba-miji/following{/other_user}",
      "gists_url": "https://api.github.com/users/alibaba-miji/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/alibaba-miji/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/alibaba-miji/subscriptions",
      "organizations_url": "https://api.github.com/users/alibaba-miji/orgs",
      "repos_url": "https://api.github.com/users/alibaba-miji/repos",
      "events_url": "https://api.github.com/users/alibaba-miji/events{/privacy}",
