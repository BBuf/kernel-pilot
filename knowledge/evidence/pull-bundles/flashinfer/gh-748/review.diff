+  int64_t v_stride_h;
+  int64_t o_stride_h;
+
+  int qo_len;
+  int kv_len;
+  int head_dim;
+  int num_qo_heads;
+  int num_kv_heads;
+  int group_size;
+  int window_left;
+
+  bool causal;
+};
+
+{{ variant_decl }}
