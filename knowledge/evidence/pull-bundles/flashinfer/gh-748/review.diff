+  using AttentionVariant = {{ variant_name }}; \
+  __VA_ARGS__(); \
+}
+
+using namespace flashinfer;
+
+using DTypeQ = {{ dtype_q }};
+using DTypeKV = {{ dtype_kv }};
+using DTypeO = {{ dtype_o }};
+using IdType = int32_t;
+constexpr int HEAD_DIM = {{ head_dim }};
