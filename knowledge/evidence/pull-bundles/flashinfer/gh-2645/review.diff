+    uint16_t f16_mantissa = static_cast<uint16_t>(f32_mantissa >> 13);
+    f16_bits = (f16_exp << 10) | f16_mantissa;
+  }
+
+  return static_cast<uint16_t>(sign >> 16) | f16_bits;
+}
