+  // fp32 has 23 mantissa bits, fp16 has 10. The 13 LSBs are the remainder.
+  // Add 13-bit random noise at bits [12:0]. Carry into bit 13 → round up.
+  abs_bits += (rand13 & 0x1FFFu);
