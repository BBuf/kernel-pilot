+    assert(fmha::FLASH_ATTEN_MASK_MMA_N / 8 == 8 && "Not supported");
+    pack_flash_attention_mask(packed_mask_h, mask_h, b, s, warps_m, warps_n, threads_per_cta,
+                              mmas_n, fmha::FLASH_ATTEN_MASK_MMA_N / 8, mask_h_row_offsets.data(),
+                              cu_mask_rows.data());
