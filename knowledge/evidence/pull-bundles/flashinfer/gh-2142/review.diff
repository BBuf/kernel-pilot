+////////////////////////////////////////////////////////////////////////////////////////////////////
+
+static inline cudaDataType_t data_type_to_cuda(Data_type dtype) {
+  switch (dtype) {
+    case DATA_TYPE_FP32:
+      return CUDA_R_32F;
+    case DATA_TYPE_FP16:
+      return CUDA_R_16F;
+    case DATA_TYPE_INT32:
+      return CUDA_R_32I;
+    case DATA_TYPE_INT8:
+      return CUDA_R_8I;
+    case DATA_TYPE_BF16:
+      return CUDA_R_16BF;
+#if FMHA_CUDA_SUPPORTS_FP8
+    case DATA_TYPE_E4M3:
+      return CUDA_R_8F_E4M3;
+    case DATA_TYPE_E5M2:
+      return CUDA_R_8F_E5M2;
+#endif
+    default:
+      assert(false);
+      return CUDA_R_32F;
+  }
+}
