+    asm volatile(
+        "mma.sync.aligned.m8n8k4.row.row.f16.f16.f16.f16 \n"
+        "    {%0, %1, %2, %3}, \n"
+        "    {%4, %5}, \n"
+        "    {%6, %7}, \n"
+        "    {%0, %1, %2, %3}; \n"
+        : "+r"(this->reg(4)), "+r"(this->reg(5)), "+r"(this->reg(6)), "+r"(this->reg(7))
+        : "r"(a.reg(2)), "r"(a.reg(3)), "r"(b.reg(6)), "r"(b.reg(7)));
+  }
+};
