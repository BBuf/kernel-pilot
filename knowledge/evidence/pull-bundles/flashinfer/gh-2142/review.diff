+  // Load a 2x4 array from registers.
+  static inline __device__ void load(int32_t (&dst)[2][4], Accumulator const& src) {
+    dst[0][0] = src.elt(0);
+    dst[0][1] = src.elt(1);
+    dst[0][2] = src.elt(2);
+    dst[0][3] = src.elt(3);
+    dst[1][0] = src.elt(4);
+    dst[1][1] = src.elt(5);
+    dst[1][2] = src.elt(6);
+    dst[1][3] = src.elt(7);
+  }
+
+  // Store to an accumulator.
+  static inline __device__ void store(Accumulator& dst, uint32_t const (&src)[2][4]) {
+    dst.reg(0) = src[0][0];
+    dst.reg(1) = src[0][1];
+    dst.reg(2) = src[0][2];
+    dst.reg(3) = src[0][3];
+    dst.reg(4) = src[1][0];
+    dst.reg(5) = src[1][1];
+    dst.reg(6) = src[1][2];
+    dst.reg(7) = src[1][3];
+  }
+};
