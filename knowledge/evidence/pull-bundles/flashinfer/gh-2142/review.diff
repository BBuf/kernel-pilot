+      uint4 data;
+      fmha::ldsm(data,
+                 read_ptr + ni * Base::ROWS_PER_WARP * Cta_tile::WARPS_N * Base::BYTES_PER_ROW);
+      static_assert(Fragment ::NUM_REGS == 4, "");
+      frag[ni].reg(0) = data.x;
