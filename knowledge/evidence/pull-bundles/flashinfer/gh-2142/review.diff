+template <typename Traits, int N>
+struct Rows_per_xor_pattern_volta_b {
+  // The size in bits.
+  enum { N_IN_BITS = N * Traits::BITS_PER_ELEMENT_B };
+
+  // The number of rows.
+  enum { VALUE = N_IN_BITS <= 256 ? 1 : (N_IN_BITS <= 512 ? 2 : 4) };
