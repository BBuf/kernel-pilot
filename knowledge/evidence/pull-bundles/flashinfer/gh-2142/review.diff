+////////////////////////////////////////////////////////////////////////////////////////////////////
+
+template <int COLS>
+struct ReadType {
+  using T = float;
+};
+
+template <>
+struct ReadType<4> {
+  using T = float;
+};
+
+template <>
+struct ReadType<8> {
+  using T = float2;
+};
