+struct Gmem_params {
+  // The matrix.
+  void* ptr;
+
+  // The stride between rows of the Q, K and V matrices.
+  int64_t stride_in_bytes;
+
+  // The number of heads
+  int h;
+
+  // Hidden dim per head
+  int d;
+
+  // array of length b+1 holding prefix sum of actual sequence lengths.
+  int* cu_seqlens;
+};
