+        k_fp8,
+        v_fp8,
+        workspace,
+        kv_lens,
+        s_qo,
+        s_kv,
+        float(bmm1_scale),
+        float(bmm2_scale),
+        -1,
+        batch_size,
+        -1,
+        qo_indptr,
+        kv_indptr,
+        False,
+        causal,
+        True,
+    )
+
+    assert out_trtllm.shape == (total_q, num_heads, head_dim)
+    assert out_trtllm.dtype == torch.bfloat16
+
+    # Reference
