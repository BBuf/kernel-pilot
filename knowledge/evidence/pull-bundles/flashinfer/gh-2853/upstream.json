    "title": "fix: int32 overflow in `trtllm_fp4_block_scale_moe` causing \"Unsupported hidden state scale shape\" for EP32+ configs",
    "user": {
      "login": "qiching",
      "id": 224643182,
      "node_id": "U_kgDODWPIbg",
      "avatar_url": "https://avatars.githubusercontent.com/u/224643182?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/qiching",
      "html_url": "https://github.com/qiching",
      "followers_url": "https://api.github.com/users/qiching/followers",
      "following_url": "https://api.github.com/users/qiching/following{/other_user}",
      "gists_url": "https://api.github.com/users/qiching/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/qiching/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/qiching/subscriptions",
      "organizations_url": "https://api.github.com/users/qiching/orgs",
      "repos_url": "https://api.github.com/users/qiching/repos",
      "events_url": "https://api.github.com/users/qiching/events{/privacy}",
