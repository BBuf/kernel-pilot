      "blob_url": "https://github.com/flashinfer-ai/flashinfer/blob/ebfd95b6af69139f35808e640df93e5047894e50/flashinfer%2Fquantization%2Ffp4_quantization.py",
      "raw_url": "https://github.com/flashinfer-ai/flashinfer/raw/ebfd95b6af69139f35808e640df93e5047894e50/flashinfer%2Fquantization%2Ffp4_quantization.py",
