+#define TLLM_LOG_WARNING(...) TLLM_CHECK_WARNING(false, __VA_ARGS__)
+
+#define TLLM_LOG_INFO(...) TLLM_CHECK_WARNING(false, __VA_ARGS__)
+
+#endif
