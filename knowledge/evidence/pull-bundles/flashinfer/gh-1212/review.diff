+#pragma once
+
+#include <iostream>
+
+#include "trtllm/gen/DtypeDecl.h"
+#include "trtllm/gen/MmaDecl.h"
+
+#ifdef TLLM_ENABLE_CUDA
+#include <cuda.h>
+#include <cutlass/cutlass.h>
+#include <cutlass/half.h>
+#endif
+
+namespace batchedGemm {
+
+namespace gemm {
