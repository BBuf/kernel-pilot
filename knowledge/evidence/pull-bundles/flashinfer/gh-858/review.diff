+      // = 1 + prefill / decode; when decode < prefill
+      const int pref_tags = prefill_slots / decode_slots;
+
+      // For this SM, what's the next operation we want to run?
+      op = (atomicAdd(&tbAssign[linear_bid], 1) % (pref_tags + 1));
+      if(op < pref_tags) {
+        op = 0;
+      } else {
