+                # head_dim,  # head_dim_vo
+                PosEncodingMode[pos_encoding_mode_d].value,
+                window_left_d != -1,  # use_sliding_window
+                logits_soft_cap_d > 0,  # use_logits_soft_cap
+            )
+            module_getter.run_tensor(
