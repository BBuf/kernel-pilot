+        out_d = torch.empty_like(q_d)
+
+        with q_p.device as device:  # device guard
+            module_getter = get_pod_module(
+                # Prefill params
+                q_p.dtype,
+                k_p.dtype,
+                q_p.dtype,
+                q_p.shape[-1],
