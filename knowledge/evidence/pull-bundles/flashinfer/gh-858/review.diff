+__global__ __launch_bounds__(std::max(
+    KTraits_P::NUM_THREADS,
+    KTraits_D::NUM_THREADS)) void PODWithKVCacheTensorKernel(const uint32_t xsize,
+                                                             const __grid_constant__ PrefillParams
