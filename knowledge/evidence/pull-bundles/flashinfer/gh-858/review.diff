+      // = 1 + decode / prefill; when prefill < decode
+      const int total_tags = decode_slots / prefill_slots + 1;
+      // For this SM, what's the next operation we want to run?
+      op = (atomicAdd(&tbAssign[linear_bid], 1) % total_tags);
+      if(op > 0) {
+        op = 1;
+      }
+    } else {
