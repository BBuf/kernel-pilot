+  linear_bid = ((int*)smem)[0];
+  op = ((int*)smem)[1];
+  // Sync to force all threads to wait
+  __syncthreads();
+
+  if(op == PREFILL) {
+    const uint32_t linear_tid = threadIdx.x;
+    // Return if threadId exceeds number of threads for this op
+    if(linear_tid >= 32 * NUM_WARPS_Q * NUM_WARPS_KV)
+      return;
