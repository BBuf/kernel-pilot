+
+        # Store original values before kernel call
+        r_original = r.clone()
+        expected_residual = x + r_original
+
+        # Call kernel - residual should be modified in-place
+        y_fp4, block_scale = add_rmsnorm_fp4quant(
+            x, r, weight, eps=eps, block_size=block_size
+        )
