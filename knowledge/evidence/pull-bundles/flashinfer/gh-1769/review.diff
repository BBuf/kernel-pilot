+      vtBar.produced.arrive();
+#endif
+      auto& xBar = smem.xBar[idxXBuf];
+      xBar.produced.arrive_and_wait();
+#if !defined(NDEBUG) && DBG_PRINT
+#if SWAP_AB
+      if (threadIdx.x == 0) {
+        printf("colMax:\n");
+        for (int i = 0; i < ctaNbQHeads; i++) {
+          printf("%f, ", smem.xColMax[idxXBuf][i]);
+        }
+        printf("\n");
+        printf("colSum:\n");
+        for (int n = 0; n < 4; n++) {
+          for (int i = 0; i < ctaNbQHeads; i++) {
