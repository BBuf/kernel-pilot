+inline constexpr uint32_t ropeNbPairsPerThrdImpl(uint32_t nbThrds) {
+  auto const val = divUp(exactDiv(validElemsPerHead, 2), nbThrds);
+  assert(val <= 32);
+  return val <= 2 ? val : (val <= 4 ? 4 : (val <= 8 ? 8 : (val <= 16 ? 16 : 32)));
+}
