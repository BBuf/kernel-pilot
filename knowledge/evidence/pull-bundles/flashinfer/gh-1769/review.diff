+        auto& xColSum = smem.xColSum[idxXBuf][warpRank];
+#pragma unroll
+        for (uint32_t n = 0; n < colMax.size; n++) {
+#pragma unroll
+          for (uint32_t j = 0; j < 2; j++) {
