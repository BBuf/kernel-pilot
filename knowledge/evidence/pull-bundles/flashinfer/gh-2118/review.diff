+def trtllm_mnnvl_allreduce(
+    input: torch.Tensor,
+    workspace: MNNVLAllreduceFusionWorkspace,
+    launch_with_pdl: bool,
+    output: Optional[torch.Tensor] = None,
+    strategy: MNNVLAllreduceFusionStrategy = MNNVLAllreduceFusionStrategy.AUTO,
