+    #     atol = 1e-2
+    # elif args.q_dtype == "fp8_e5m2": # E5M2 not tested yet
+    #     q_dtype = torch.float8_e5m2
+    else:
+        raise ValueError(f"Unsupported q_dtype: {args.q_dtype}")
+
+    # Handle different KV cache data types. TO-DO: Add support for fp8.
