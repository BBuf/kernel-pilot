+            use_cuda_graph=is_cuda_graph_compatible,
+            use_tensor_cores=True,
+            paged_kv_indptr_buffer=kv_indptr_for_trtllm,
+            paged_kv_indices_buffer=kv_indices,
+            paged_kv_last_page_len_buffer=kv_last_page_len,
+            backend="trtllm-gen",
