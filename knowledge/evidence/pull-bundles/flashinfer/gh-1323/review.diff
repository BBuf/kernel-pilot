+    if args.verbose >= 2:
+        print(f"[VVERBOSE] {q.shape = }")
+
+    # Create KV cache
+    num_pages_per_seq = (s_kv + page_size - 1) // page_size
+    total_num_pages = num_pages_per_seq * batch_size
+
+    if args.verbose >= 2:
+        print(f"[VVERBOSE] {num_pages_per_seq = }")
