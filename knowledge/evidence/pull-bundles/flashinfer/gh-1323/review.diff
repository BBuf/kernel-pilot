+        start_idx = kv_indptr[i]
+        end_idx = kv_indptr[i + 1]
+        kv_indices[start_idx:end_idx] = torch.arange(
+            i * num_pages_per_seq,
+            i * num_pages_per_seq + (end_idx - start_idx),
+            device=device,
+        )
+
+    kv_last_page_len = (
+        torch.where(
+            actual_seq_lens_kv.flatten() % page_size == 0,
