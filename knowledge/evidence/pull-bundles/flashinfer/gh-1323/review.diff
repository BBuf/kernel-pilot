+        print(f"[VVERBOSE] {kv_indptr.shape = }")
+        print(f"[VVERBOSE] {kv_indices.shape = }")
+        print(f"[VVERBOSE] {kv_last_page_len.shape = }")
+        print(f"[VVERBOSE] {scale = }")
+
+    # Prepare wrappers
