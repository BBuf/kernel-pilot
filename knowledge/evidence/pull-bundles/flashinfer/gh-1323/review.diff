+    # elif args.kv_dtype == "fp8" or args.kv_dtype == "fp8_e4m3fn":
+    #     kv_dtype = torch.float8_e4m3fn
+    #     rtol = 2e-1
+    #     atol = 1e-2
+    # elif args.kv_dtype == "fp8_e5m2": # E5M2 not tested yet
+    #     kv_dtype = torch.float8_e5m2
