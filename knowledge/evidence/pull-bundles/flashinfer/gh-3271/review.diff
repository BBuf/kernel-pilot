+            while is_valid_tile:
+                tc = tile_coord
+                intermediate_slice = tc[1]
+                local_expert_idx = tc[2]
+                if cutlass.const_expr(self.single_token):
+                    weight_expert_idx = topk_ids[local_expert_idx].to(Int32)
+                else:
