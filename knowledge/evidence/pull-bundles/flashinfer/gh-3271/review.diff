+        self.single_token = single_token
+        self.dynamic_down_scale = dynamic_down_scale
+        self.w4a16_mode = w4a16_mode
+        self._cfg = cast(_ShapeConfig, None)
+        self.m_const = 0
+        self.m1_fc2_onepass = False
+        self.grid_x = 0
