+                    # DMA warp waits here too after finishing all B_down loads.
+                    self.pass_sync_barrier.arrive_and_wait()
+                    slice_idx += Int32(1)
+
+            elif (
+                warp_idx >= self.tma_load_warp_id
+                and warp_idx < self.tma_load_warp_id + self.num_load_warps
+            ):
