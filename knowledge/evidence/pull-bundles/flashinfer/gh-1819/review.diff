+static int kNumDeviceSMs = -1;
+static bool kDeepGemmEnabled = []() -> bool {
+  char const* env_var = std::getenv("TRTLLM_DG_ENABLED");
+  return deep_gemm::jit::getGlobalCompiler().isValid() && (!env_var || std::string(env_var) != "0");
+}();
