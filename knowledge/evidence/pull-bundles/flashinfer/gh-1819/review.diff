+  static constexpr GemmType gemm_type = GemmType::GroupedMasked;
+
+  int current_iter = -1;
+  uint32_t num_blocks;
+  uint32_t num_aligned_m_blocks;
+  uint32_t curr_group_idx;
+  uint32_t curr_cumsum;
+  uint32_t shape_m;
+  int* grouped_layout;
+
+  using Input = GroupedMaskedSchedulerInput;
+  Input input;
+
