+// Get 1D ctaid in a cluster.
+CUTE_DEVICE uint32_t block_rank_in_cluster() {
+#if defined(CUTE_ARCH_CLUSTER_SM90_ENABLED)
+  uint32_t rank;
+  asm volatile("mov.u32 %0, %%cluster_ctarank;\n" : "=r"(rank) :);
