+  __device__ __forceinline__ bool get_next_block(uint32_t& m_block_idx, uint32_t& n_block_idx) {
+    ++current_iter;
+    auto const next_block_idx = current_iter * gridDim.x + blockIdx.x;
+    uint32_t num_m_blocks;
