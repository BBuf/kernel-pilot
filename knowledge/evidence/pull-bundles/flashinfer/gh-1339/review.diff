+                    (void*)&quant_scale_q,
+                    (void*)&quant_scale_kv};
+    auto kernel = MLARopeQuantizeKernel<INTERLEAVE, vec_size, bdx, DType, IdType, QuantType>;
+    dim3 nblks(nblks_x, num_heads + 8 + 1 + num_heads * 8);
+    dim3 nthrs(bdx, bdy);
+    FLASHINFER_CUDA_CALL(cudaLaunchKernel((void*)kernel, nblks, nthrs, args, 0, stream));
+  });
+
+  return cudaSuccess;
+}
