--- /dev/null
+++ b/tests/autotuner/utils.py
@@ -0,0 +1,9 @@
+from flashinfer.autotuner import AutoTuner
+
+
+def reset_autotuner() -> AutoTuner:
+    tuner = AutoTuner.get()
+    tuner.clear_cache()
+    tuner.reset_statistics()
+    tuner.is_tuning_mode = False
+    return tuner
