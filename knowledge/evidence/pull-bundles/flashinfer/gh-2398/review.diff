+        can_implement = True
+
+        # Skip unsupported A/B layout
+        if not (a_major == "k" and b_major == "k"):
+            can_implement = False
+
+        # Skip unsupported types
+        if not Sm100BlockScaledContiguousGroupedGemmKernel.is_valid_dtypes_and_scale_factor_vec_size(
