+    output_scale = nvfp4_compute_output_scale(scale_fp8_u32, global_scale)
+
+    # Convert to E2M1 and pack
+    packed64 = half2x8_to_e2m1x16_packed(h0, h1, h2, h3, h4, h5, h6, h7, output_scale)
+
+    return scale_fp8, packed64
