+# ---------------------------------------------------------------------------
+# Tests: end-to-end save -> load -> search_cache
+# ---------------------------------------------------------------------------
+
+
+class TestEndToEnd:
+    def setup_method(self):
+        AutoTuner._instance = None
+        self.tuner = AutoTuner.get()
+
+    def teardown_method(self):
+        AutoTuner._instance = None
+
+    def test_save_then_load_then_search(self):
