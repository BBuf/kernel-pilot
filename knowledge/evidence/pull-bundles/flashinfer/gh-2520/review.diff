+        ".reg .b32 sf2;\n"
+        "mov.b32 sf2, {%2, %2};\n"
+        "mul.rn.bf16x2 %0, %1, sf2;\n"
+        "}"
+        : "=r"(ret)
+        : "r"(x), "h"(sf));
