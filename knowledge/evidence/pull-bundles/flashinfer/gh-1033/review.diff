-  if (cu_seqlens_q_d == nullptr) {
-    params.q_batch_stride = q.stride(0);
-    params.k_batch_stride = k.stride(0);
-    params.v_batch_stride = v.stride(0);
-    params.o_batch_stride = out.stride(0);
