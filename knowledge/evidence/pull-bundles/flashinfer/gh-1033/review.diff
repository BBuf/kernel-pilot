-
-  // P = softmax(QK^T)
-  params.p_ptr = p_d;
-
-  // Softmax sum
-  params.softmax_lse_ptr = softmax_lse_d;
-
-  // Set the dimensions.
-  params.b = b;
-  params.h = h;
-  params.h_k = h_k;
