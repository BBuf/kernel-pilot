-// Simple packed vector type for loading N elements of type T
-template <typename T, int N = sizeof(float4) / sizeof(T)>
-struct alignas(N * sizeof(T)) PackedAligned {
-  T val[N];
-  static constexpr int count = N;
-  using dtype = T;
-};
