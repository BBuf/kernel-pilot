+  using matrixA_t = typename DTypeToType<matrixA_code>::type;
+  using stateIndex_t = typename DTypeToType<stateIndex_code>::type;
+  mtp::invokeSelectiveStateUpdateMTP<input_t, weight_t, matrixA_t, state_t, stateIndex_t>(p,
+                                                                                          stream);
+}
