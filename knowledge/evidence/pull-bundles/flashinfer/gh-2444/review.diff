+};
+template <>
+struct DTypeToType<float32_code> {
+  using type = float;
+};
+template <>
+struct DTypeToType<int32_code> {
+  using type = int32_t;
+};
+template <>
+struct DTypeToType<int64_code> {
+  using type = int64_t;
+};
