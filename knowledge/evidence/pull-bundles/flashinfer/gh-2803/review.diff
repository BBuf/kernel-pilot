-  // Write CTA configs for each expert this thread handles
-#pragma unroll
-  for (int e = 0; e < ExpertsPerThread; e++) {
-    int expert = threadIdx.x * ExpertsPerThread + e;
-    auto localExpIdx = expert - params.mLocalExpertsStartIdx;
