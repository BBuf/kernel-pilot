+@dsl_user_op
+def bfloat2_add(a: Uint32, b: Uint32, *, loc=None, ip=None) -> Uint32:
+    """Add two BFloat2 values element-wise: (a.x+b.x, a.y+b.y)."""
+    return Uint32(
+        llvm.inline_asm(
+            T.i32(),
+            [Uint32(a).ir_value(loc=loc, ip=ip), Uint32(b).ir_value(loc=loc, ip=ip)],
+            "add.bf16x2 $0, $1, $2;",
