+        batch_size=4,
+        num_q_heads=16,
+        num_k_heads=16,
+        num_v_heads=32,
+        head_size=128,
+        scale=1.0,
+        alpha=True,
+        beta=True,
+        seed=42,
+    )
+
+    print("\n=== Testing NONTRANSPOSE version ===")
