+        batch_size=4,
+        num_q_heads=16,
+        num_k_heads=16,
+        num_v_heads=32,
+        head_size=128,
+        scale=1.0,
+        alpha=True,
+        beta=True,
+        seed=42,
+    )
+
+    print("\n=== Testing MTP (VERIFY) version ===")
+    _test_verify_kernel_mtp(
+        dtype="bfloat16",
+        batch_size=4,
+        num_q_heads=16,
+        num_k_heads=16,
+        num_v_heads=32,
+        head_size=128,
+        seq_len=4,  # T > 1 for MTP
+        scale=1.0,
+        alpha=True,
+        beta=True,
+        cache_intermediate_states=True,
+        seed=42,
+    )
+
+    print("\n✅ All smoke tests passed!")
