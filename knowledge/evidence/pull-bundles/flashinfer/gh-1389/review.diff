+        dtype=torch.int32,
+    )
+    paged_kv_last_page_len_host = torch.full((batch_size,), 1, dtype=torch.int32)
+    wrapper_paged.plan(
+        qo_indptr_host,
+        kv_indptr_host,
+        kv_indices_host,
