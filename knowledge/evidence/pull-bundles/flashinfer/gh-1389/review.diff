-      // Use routingTopKExperts function instead of inline logic
-      routingTopKExperts<InputT, ExpertsPerThread>(warp, warpMaxScore, warpMaxExpertIdx,
-                                                   threadIdx.x, params.mNumExperts,
-                                                   params.mPtrScores + scoreOffset);
