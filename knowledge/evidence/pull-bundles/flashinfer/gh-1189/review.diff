+        v_seq = torch.repeat_interleave(v_seq, head_grp_size, dim=0)
+        output[b] = scaled_dot_product(
+            q_b.unsqueeze(0), k_seq.unsqueeze(0), v_seq.unsqueeze(0)
+        ).squeeze()
+
