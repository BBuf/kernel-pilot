+                qkv_len,
+                num_qo_heads,
+                num_kv_heads,
+                head_dim_qk,
+                head_dim_vo,
+                causal,
+                torch.float8_e4m3fn,
+                o_data_type=torch.bfloat16,
+            )
+            result_fp8["config_name"] = config_name
+            results.append(result_fp8)
+            speedup = result_fp8["tflops"] / result_bf16["tflops"]
+            print(
