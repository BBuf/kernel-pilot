+          workspaceBytes, stream, occupancy);
+      break;
+    case ClusterShape::ClusterShape_2x2x1:
+      return genericFp4GemmKernelLauncher<T, CTA_M_, CTA_N_, CTA_K_, cute::Int<2>, cute::Int<2>,
