-
-  // Compute the max inside the thread.
-#pragma unroll
-  for (int ii = 0; ii < N; ++ii) {
-    max_fp32 = fmaxf(max_fp32, data_fp32[ii][0]);
-  }
-
-// Compute inside the warp.
