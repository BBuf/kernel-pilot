+def get_effective_sm_and_name(kspec):
+    sm = kspec.sm
+    # Override the mma instruction with an older one.
+    if kspec.sm_mma in sm2name:
+        assert kspec.sm_mma <= kspec.sm, (
+            "Instruction version should be at most target arch"
+        )
+        sm = kspec.sm_mma
+    sm_name = sm2name[sm]
+    return sm, sm_name
