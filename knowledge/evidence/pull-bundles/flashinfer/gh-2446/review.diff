+    if seqlen >= 1024 and not kernel_spec.flash_attention:
+        fname += ".no_i2f_f2i"
+    fname += ".cu"
+    lname = ("run_" + name_base).replace("__placeholder__", "")
+    kname = name_base + "_kernel"
+
+    # remove causal
+    fname = fname.replace("causal_", "")
+    return fname, lname, kname
