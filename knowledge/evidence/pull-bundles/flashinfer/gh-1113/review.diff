+template <typename T_IN, typename T_OUT>
+__global__ void cudaD2DScaleCpyConvert(T_OUT* dst, const T_IN* src, float const* scale,
+                                       bool invert_scale, const size_t size) {
+  float const scale_value = invert_scale ? 1.0f / scale[0] : scale[0];
+  for (size_t tid = threadIdx.x + blockIdx.x * blockDim.x; tid < size;
+       tid += blockDim.x * gridDim.x) {
+    dst[tid] = cuda_cast<T_OUT>(cuda_cast<float>(src[tid]) * scale_value);
+  }
+}
