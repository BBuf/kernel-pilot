+class LoraImpl {
+ public:
+  LoraImpl(int in_hidden_size, std::vector<int> out_hidden_sizes, bool transA, bool transB,
+           int num_lora_modules, nvinfer1::DataType type, int max_low_rank,
+           std::shared_ptr<CublasGemmWrapper> cublasWrapper);
