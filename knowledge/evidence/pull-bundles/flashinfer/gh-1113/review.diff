+__global__ void cudaCast(T_OUT* dst, T_IN* src, const size_t size) {
+  for (size_t tid = threadIdx.x + blockIdx.x * blockDim.x; tid < size;
+       tid += blockDim.x * gridDim.x) {
+    dst[tid] = (T_OUT)((float)(src[tid]));
+  }
+}
