+            / "nv_internal/tensorrt_llm/kernels/preQuantScaleKernel.cu",
+            jit_env.FLASHINFER_CSRC_DIR
+            / "nv_internal/tensorrt_llm/kernels/cutlass_kernels/cutlass_heuristic.cpp",
