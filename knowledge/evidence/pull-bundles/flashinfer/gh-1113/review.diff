+  int mSM{};
+  int64_t mNumExperts{};
+  int64_t mNumExpertsPerNode{};
+  int64_t mK{};
+  int64_t mExpertHiddenSize{};
+  int64_t mExpertInterSize{};
+  int64_t mGroupSize{};
+  ActivationType mActivationType{};
+  MOEParallelismConfig mParallelismConfig{};
+
+  int mSampleIndex = 0;
