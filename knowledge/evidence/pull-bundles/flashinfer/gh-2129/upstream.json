      "patch": "@@ -67,11 +67,12 @@ def bench_mm_fp8(m, n, k, in_dtype, out_dtype):\n             input_fp8,\n             prepared_weights,\n             global_scale,\n-            res,\n+            out=res,\n         ),\n-        dry_run_time_ms=500,\n-        repeat_time_ms=2500,\n+        dry_run_time_ms=25,\n+        repeat_time_ms=100,  # 100ms should be enough for low latency kernels that run within 100 usec\n         use_cuda_graph=True,\n+        enable_cupti=True,\n     )\n     ms = np.median(measurements)\n     tflops_per_second = 2 * m * n * k * 1e-9 / ms"
