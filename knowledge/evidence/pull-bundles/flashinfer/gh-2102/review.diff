+      break;                                        \
+    }                                               \
+    case 4: {                                       \
+      constexpr int TOP_K = 4;                      \
+      __VA_ARGS__;                                  \
+      break;                                        \
+    }                                               \
+    case 2: {                                       \
+      constexpr int TOP_K = 2;                      \
+      __VA_ARGS__;                                  \
+      break;                                        \
+    }                                               \
+    case 1: {                                       \
+      constexpr int TOP_K = 1;                      \
+      __VA_ARGS__;                                  \
+      break;                                        \
+    }                                               \
+    default: {                                      \
+      FLASHINFER_CHECK(false, "Unsupported top_k"); \
