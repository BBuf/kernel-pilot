+
+    if distribution == "random":
+        torch.manual_seed(0xD5)
+        all_num_tokens = torch.randint(1, 100, (world_size,)).tolist()
+    elif distribution == "uniform":
+        all_num_tokens = [50] * world_size
+    else:
