+    def dequantize(weights, scales):
+        k = weights.shape[-1] * 2
+        n = weights.shape[-2]
+        # Unpack two 4-bit values (stored in two's-complement) from each byte
+        weights_int8 = (
+            torch.stack([weights & 0x0F, (weights >> 4) & 0x0F], dim=-1)
+            .reshape(num_experts, n, k)
