-    return topk::MaxNumExpertsUnit;
-  } else if (numExperts <= NumExpertsLimit) {
-    return NumExpertsLimit;
-  } else {
-    TLLM_LOG_ERROR("Unsupported numExperts");
-    return 0;
-  }
-}
