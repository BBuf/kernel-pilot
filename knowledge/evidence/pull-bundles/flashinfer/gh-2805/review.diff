-    @cute.jit
-    def exchange_p_cor_metadata(
-        self,
-        common_params: SimpleNamespace,
-        softmax_params: SimpleNamespace,
-        correction_factor: cutlass.Float32,
-        row_sum: cutlass.Float32,
-        row_max: cutlass.Float32,
