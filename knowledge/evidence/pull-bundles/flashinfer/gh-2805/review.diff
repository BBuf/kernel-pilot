-    @cute.jit
-    def initialize_workspace(
-        self,
-        H: cutlass.Int32,
-        D: cutlass.Int32,
-        S: cutlass.Int32,
-        B: cutlass.Int32,
-        split_kv: cutlass.Int32,
-        acc_dtype: Type[cutlass.Numeric],
-        workspace: cute.Tensor,
