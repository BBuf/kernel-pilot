-    def get_correction_factor(
-        self,
-        common_params: SimpleNamespace,
-        p_cor_consumer_state: pipeline.PipelineState,
-    ) -> tuple[
-        pipeline.PipelineState,
-        cutlass.Float32,
-        cutlass.Float32,
-        cutlass.Float32,
-        cutlass.Int32,
-    ]:
-        """Get the correction factor from the P correction consumer state.
