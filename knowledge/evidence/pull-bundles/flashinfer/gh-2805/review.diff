-    def torch_reference_mla(
-        q_latent,
-        q_rope,
-        c_latent,
-        c_rope,
-        page_table,
-        cache_seqs,
-        softmax_scale=1.0,
-        output_scale=1.0,
-    ):
-        # Ref tensors are now contiguous:
-        #   q_latent/q_rope: [B, S_q, H, D]
-        #   c_latent/c_rope: [num_pages, page_size, D]
