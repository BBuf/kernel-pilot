-        cute.copy(
-            corr_tmem_load_tiled_copy,
-            tCor_for_copy[None, None, None, p_cor_consumer_state.index],
-            rCor,
-        )
-        row_sum = rCor[0]
-        row_max = rCor[1]
-        correction_factor = rCor[2]
