-    @cute.jit
-    def load_tma_qk(
-        self,
-        common_params: SimpleNamespace,
-        qk_params: SimpleNamespace,
-        k_index: cutlass.Int32,
-        k_tile_count: cutlass.Int32,
-        load_q_producer_state: pipeline.PipelineState | None = None,
