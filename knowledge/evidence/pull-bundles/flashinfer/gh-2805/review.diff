-                    tiled_mma_pv,
-                    load_v_consumer_state,
-                    p_mma_consumer_state,
-                    mma_o_producer_state,
-                ) = self.mma_pv(
-                    common_params,
-                    pv_params,
-                    tiled_mma_pv,
-                    load_v_consumer_state,
-                    p_mma_consumer_state,
-                    mma_o_producer_state,
