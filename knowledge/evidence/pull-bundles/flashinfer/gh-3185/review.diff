+            expected GLM-MoE-DSA router configuration.
+
+    Note:
+        This kernel is specialized for compute capability 10.0 (Blackwell architecture).
+    """
+    get_dsv3_router_gemm_module().mm_M1_16_K6144_N256(
+        mat_a, mat_b, out, launch_with_pdl
