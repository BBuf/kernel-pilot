+    major_b: MajorTypeAB,
+    major_d: MajorTypeCD,
+    compiled_dims: str,
+    output_dtype: torch.dtype,
+):
+    num_sms = torch.cuda.get_device_properties(device="cuda").multi_processor_count
+    num_sms, block_m, block_n, block_k, num_stages, multicast_config, smem_config = (
+        get_best_configs(
+            GemmType.GroupedMasked,
+            expected_m,
+            n,
+            k,
+            num_groups,
+            major_a,
+            major_b,
+            major_d,
+            torch.float8_e4m3fn,
+            output_dtype,
+            num_sms,
+        )
+    )
+    if num_groups > 1:
+        assert m % block_m == 0
+
+    kwargs = {
