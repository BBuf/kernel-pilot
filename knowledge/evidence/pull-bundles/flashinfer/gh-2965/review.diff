+constexpr __device__ int32_t find_largest_divisor(int32_t n, int32_t divisor_upper_bound) {
+  if (n <= divisor_upper_bound) {
+    return n;
+  }
+  for (int32_t i = divisor_upper_bound; i >= 1; --i) {
+    if (n % i == 0) {
+      return i;  // found the largest divisor
+    }
+  }
+  return divisor_upper_bound;  // fallback
+}
