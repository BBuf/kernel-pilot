+        query,
+        kv_cache,
+        block_tables,
+        seq_lens,
+        causal=True,
+        bmm1_scale=bmm1_scale,
+        bmm2_scale=bmm2_scale,
+        cum_seq_lens_q=cum_seq_lens_q,
+    )
