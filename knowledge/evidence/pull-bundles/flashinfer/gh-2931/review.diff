+@torch.no_grad()
+def _trtllm_fp8_block_scale_routed_moe_reference(
+    topk_ids,
+    hidden_states,
+    hidden_states_scale,
+    gemm1_weights,
+    gemm1_weights_scale,
+    gemm2_weights,
+    gemm2_weights_scale,
+    num_experts,
+    top_k,
+    local_expert_offset,
+    routed_scaling_factor=None,
+    **_unused,
+):
+    """Reference for TRT-LLM FP8 block-scale routed MoE (precomputed topk_ids).
+
+    Reuses ``_fp8_moe_run_experts`` for the dequant + SwiGLU path, and builds
+    a uniform per-token weight tensor (real routing scales are not available
+    from topk_ids alone).
+    """
+    T = topk_ids.shape[0]
+    TOP_K = int(top_k)
+    scale = float(routed_scaling_factor or 1.0)
+    w_topk = torch.full(
+        (T, TOP_K),
+        scale / TOP_K,
+        dtype=torch.float32,
+        device=hidden_states.device,
+    )
+    return _fp8_moe_run_experts(
+        hidden_states,
+        hidden_states_scale,
+        gemm1_weights,
+        gemm1_weights_scale,
+        gemm2_weights,
+        gemm2_weights_scale,
+        w_topk,
+        topk_ids.to(torch.int64),
+        local_expert_offset,
+        int(num_experts),
+    )
