+{
+  "name": "moe_fp8_block_scale_topk_routing_topk8_e32_h7168_i2048",
+  "description": "FP8 block scale MoE with TopK-only routing (no softmax, uniform weights).",
+  "op_type": "moe",
+  "tags": [
+    "fi_api:flashinfer.fused_moe.core.trtllm_fp8_block_scale_moe",
