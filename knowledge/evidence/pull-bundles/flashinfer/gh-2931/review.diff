+    fc2_expert_weights,
+    **_unused,
+):
+    """Reference for CUTLASS fused MoE with precomputed routing."""
+    E_global = fc1_expert_weights.shape[0]
+    return _moe_bf16_run_experts(
+        input,
+        fc1_expert_weights,
+        fc2_expert_weights,
+        token_final_scales,
+        token_selected_experts.to(torch.int64),
+        local_expert_offset=0,
+        E_global=E_global,
+    )
