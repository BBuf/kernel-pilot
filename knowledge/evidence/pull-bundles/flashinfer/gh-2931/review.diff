+    ),
+    "pos_ids": Tensor(["nnz"], dtype="int32"),
+    "is_neox": Scalar(
+        "int32",
+        optional=True,
+        description="Bool: Neox half-split (True) vs interleaved (False).",
+    ),
+    "quant_scale_q": Scalar("float32", optional=True),
+    "quant_scale_kv": Scalar("float32", optional=True),
+}
+
