+        "A is [M, K] float8_e4m3fn; B is [K//block_size, N, block_size] float8_e4m3fn."
+    ),
+    axes={
+        "M": Var(),
+        "N": Const(),
+        "K": Const(),
+    },
+    inputs={
+        "A": Tensor(["M", "K"], param="a"),
+        "B": Tensor(
+            ["K_div_block_size", "N", "block_size"],
+            param="b",
+            description="FP8 weight in TRT-LLM block layout [K//block_size, N, block_size].",
+        ),
+    },
