+{
+  "name": "fp4_quantize_k4096",
+  "description": "Generic FP4 quantization: bf16/fp16 input \u2192 packed FP4 e2m1fn + block scales.",
+  "op_type": "quantization",
+  "tags": [
+    "fi_api:flashinfer.quantization.fp4_quantization.fp4_quantize",
