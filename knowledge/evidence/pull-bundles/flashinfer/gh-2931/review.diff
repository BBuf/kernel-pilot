+def test_mm_bf16_reference_correctness():
+    """flashinfer.mm_bf16 kernel vs reference (plain matmul).
+
+    B must be column-major (stride [1, K]) for mm_bf16; the reference
+    computes C = A @ B assuming that physical layout.
