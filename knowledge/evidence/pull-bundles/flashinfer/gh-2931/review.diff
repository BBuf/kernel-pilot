+{
+  "name": "top_k_mask_logits_v32000",
+  "description": "Mask out-of-top-k logits to -inf.",
+  "op_type": "sampling",
+  "tags": [
+    "fi_api:flashinfer.sampling.top_k_mask_logits",
+    "status:verified"
+  ],
+  "axes": {
+    "batch_size": {
+      "type": "var"
+    },
+    "vocab_size": {
+      "type": "const",
+      "value": 32000
+    }
