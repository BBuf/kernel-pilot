+        dtype="uint8",
+        description="Packed FP4 e2m1_x2 output.",
+    ),
+    "block_scale": Tensor(
+        ["num_tokens", "hidden_div_block_size"],
+        dtype="float8_e4m3fn",
+        description="Per-block absmax-derived scale.",
+    ),
+}
+
+
+rmsnorm_fp4quant_trace = TraceTemplate(
+    op_type="rmsnorm",
