+    seq_lens = torch.tensor(kv_lens, dtype=torch.int32, device="cuda")
+    cum_list = [0] + [sum(q_lens[: i + 1]) for i in range(B)]
+    cum = torch.tensor(cum_list, dtype=torch.int32, device="cuda")
