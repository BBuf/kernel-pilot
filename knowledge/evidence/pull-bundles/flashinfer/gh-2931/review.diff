+mm_mxfp8_trace = TraceTemplate(
+    op_type="gemm_mxfp8",
+    description=(
+        "MXFP8 GEMM C = A @ B (MX block size 32). "
+        "A and B are float8_e4m3fn; scale tensors use block size 32."
