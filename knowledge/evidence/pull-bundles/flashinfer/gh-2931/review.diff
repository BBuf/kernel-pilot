+    k_nope = torch.randn(nnz, nope_dim, dtype=torch.bfloat16, device=device)
+    t = torch.arange(4096, dtype=torch.float32, device=device)
+    inv_freq = 1.0 / (
+        1e4
+        ** (torch.arange(0, rope_dim, 2, dtype=torch.float32, device=device) / rope_dim)
+    )
