+
+        moe_local_gather(
+            recv_rank_count_cumsum,
+            local_gather_indices,
+            gathered_expert_ids,
+            gathered_scales,
+            local_expert_ids,
+            local_scales,
+            max_token_count_per_rank,
+            expert_count,
+            top_k,
+            ep_rank,
+            ep_size,
+        )
