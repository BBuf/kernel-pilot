+            top_k,
+            ep_rank,
+            ep_size,
+        )
+
+        local_token_allocation_count = max_token_count_per_rank * ep_size
+
+        local_expert_ids = torch.empty(
+            local_token_allocation_count,
+            top_k,
+            dtype=torch.int32,
+            device=torch.device("cuda"),
