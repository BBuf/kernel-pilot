+            ),
+        )
+
+        tCgSFB = cute.make_tensor(
+            gSFB_nkl.iterator,
+            cute.tiled_divide(
+                gSFB_nkl.layout, (self.mma_sf_tiler[1], self.mma_sf_tiler[2])
+            ),
+        )
+        tCgC = thr_mma.partition_C(gC_mnl)
+
