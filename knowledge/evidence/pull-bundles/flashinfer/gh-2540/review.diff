+                            tBsB[(None, ab_empty.index)],
+                            tma_bar_ptr=ab_empty.barrier,
+                            mcast_mask=b_full_mcast_mask,
+                        )
+
+                        # Peek (try_wait) AB buffer empty for next buffer
+                        peek_ab_empty_status = cutlass.Boolean(1)
