+            idC, cute.slice_(self.mma_tiler, (None, None, 0)), (None, None, None)
+        )
+        # (MMA, MMA_M, MMA_N, RestM, RestN, RestL)
+        tCcC = thr_mma.partition_C(cC_mnl)
+
