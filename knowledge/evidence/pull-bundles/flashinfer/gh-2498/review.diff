+@cute.jit
+def gated_delta_rule_launch_seqlen1(
+    mQ: cute.Tensor,
+    mK: cute.Tensor,
+    mV: cute.Tensor,
+    ma: cute.Tensor,
+    mb: cute.Tensor,
+    mA_log: cute.Tensor,
