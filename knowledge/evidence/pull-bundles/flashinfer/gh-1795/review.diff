-    if (scale_major_mode == 0) {                                          \
-      constexpr bool SCALE_MAJOR_K = true;                                \
-      return __VA_ARGS__();                                               \
-    } else if (scale_major_mode == 1) {                                   \
-      constexpr bool SCALE_MAJOR_K = false;                               \
-      return __VA_ARGS__();                                               \
-    }                                                                     \
-    CHECK(false) << "Unsupported Scale Major Mode: " << scale_major_mode; \
-    return false;                                                         \
-  }()
