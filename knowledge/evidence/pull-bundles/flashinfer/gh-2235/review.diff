-  }
-
-  // When one of the inputs needs to be cast, we must use two load warps.
-  if ((options.mDtypeMmaA != options.mDtypeA || options.mDtypeMmaB != options.mDtypeB) &&
-      !options.mUseTwoTmaLoadWarps) {
