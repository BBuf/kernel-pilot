-                             /*oobFill=*/CU_TENSOR_MAP_FLOAT_OOB_FILL_NONE);
-
-  if (result != CUDA_SUCCESS) {
-    char const* errorString;
-    cuGetErrorString(result, &errorString);
-    std::stringstream ss;
-    ss << "Error: Failed to initialize the TMA descriptor. " << errorString << std::endl;
-
-    ss << "tmaFormat: " << static_cast<int>(tmaDataFormat) << " dim: " << dim
-       << " gmem: " << gmemAddr << std::endl;
-
-    ss << "Shape: ";
-    for (int ii = 0; ii < dim; ++ii) {
-      ss << shapes[ii] << " ";
-    }
-    ss << std::endl;
-
-    ss << "Stride: ";
-    for (int ii = 0; ii < dim - 1; ++ii) {
-      ss << stridesInBytes[ii] << " ";
-    }
-    ss << std::endl;
-
-    ss << "tileShapes: ";
