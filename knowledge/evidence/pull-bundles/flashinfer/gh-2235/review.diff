-  //////////////////////////////////////////////////////////////////////////////////////////////////
-
-  // Returns the list of all available cubin configurations
-  BatchedGemmConfig const* getBatchedGemmConfigs() const {
-#ifdef TLLM_GEN_EXPORT_INTERFACE
-    return tensorrt_llm::kernels::tllmGenBatchedGemmList;
-#else
-    return nullptr;
-#endif
-  }
