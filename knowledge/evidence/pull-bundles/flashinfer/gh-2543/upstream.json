      "blob_url": "https://github.com/flashinfer-ai/flashinfer/blob/c576fdd71c9c7dd6b47bdc80963b0dcff5dee699/flashinfer%2Ftriton%2F__init__.py",
      "raw_url": "https://github.com/flashinfer-ai/flashinfer/raw/c576fdd71c9c7dd6b47bdc80963b0dcff5dee699/flashinfer%2Ftriton%2F__init__.py",
      "contents_url": "https://api.github.com/repos/flashinfer-ai/flashinfer/contents/flashinfer%2Ftriton%2F__init__.py?ref=c576fdd71c9c7dd6b47bdc80963b0dcff5dee699",
      "patch": "@@ -1,2 +1,28 @@\n+import os\n+import shutil\n+import subprocess\n+import re\n+\n+\n+def _patch_triton_ptxas_blackwell():\n+    \"\"\"Point Triton at the system ptxas for Blackwell (CUDA >= 13).\"\"\"\n+    if os.environ.get(\"TRITON_PTXAS_BLACKWELL_PATH\"):\n+        return\n+    ptxas = shutil.which(\"ptxas\")\n+    if not ptxas:\n+        return\n+    try:\n+        out = subprocess.check_output(\n+            [ptxas, \"--version\"], stderr=subprocess.STDOUT\n+        ).decode()\n+    except subprocess.CalledProcessError:\n+        return\n+    m = re.search(r\"release (\\d+)\\.\", out)\n+    if m and int(m.group(1)) >= 13:\n+        os.environ[\"TRITON_PTXAS_BLACKWELL_PATH\"] = ptxas\n+\n+\n+_patch_triton_ptxas_blackwell()\n+\n from . import cascade  # noqa: F401\n from . import sm_constraint_gemm  # noqa: F401"
    }
  ],
