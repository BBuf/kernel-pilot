+@cute.jit
+def max_abs_16(values: cute.Tensor) -> Float32:
+    """Compute the maximum absolute value of 16 float32 values."""
+    result = fabs_f32(values[0])
+    for i in cutlass.range_constexpr(1, 16):
+        result = fmax_f32(result, fabs_f32(values[i]))
+    return result
+
