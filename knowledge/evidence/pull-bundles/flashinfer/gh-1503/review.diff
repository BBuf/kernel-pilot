+  template <typename T, uint32_t size>                                              \
+  __device__ __host__ inline Vec<decltype(op(mha::declval<T>())), size> op(         \
+      Vec<T, size> const& a) {                                                      \
+    Vec<decltype(op(mha::declval<T>())), size> result;                              \
+    _Pragma("unroll") for (uint32_t i = 0; i < size; i++) { result[i] = op(a[i]); } \
+    return result;                                                                  \
+  }
