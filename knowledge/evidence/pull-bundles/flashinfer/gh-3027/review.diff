+        num_tokens, -1
+    )
+
+    w13_global_amax = w13_bf16.abs().amax().to(torch.float32)
+    w2_global_amax = w2_bf16.abs().amax().to(torch.float32)
+    w13_global_scale_inv = nvfp4_global_decode_scale_te(w13_global_amax)
