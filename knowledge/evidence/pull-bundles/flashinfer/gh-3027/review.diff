+  static constexpr int ELTS_PER_THREAD = 8;
+  static constexpr int SF_VEC_SIZE = 16;
+  static constexpr int NUM_THREADS_PER_SF = SF_VEC_SIZE / ELTS_PER_THREAD;  // 2
