+  printf("%s:%d [WG%d][W%d][T%-3d] " fmt, __FILE__, __LINE__, threadIdx.x / 128, threadIdx.x / 32, \
+         threadIdx.x, ##__VA_ARGS__)
+#else
+#define DPRINTF(...)
