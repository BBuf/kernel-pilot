+def get_sm_count_constraint(major: int, minor: int) -> Tuple[int, int]:
+    if major == 6:
+        return (1, 1)
+    elif major == 7:
+        return (2, 2)
+    elif major == 8:
+        return (4, 2)
+    elif major >= 9:
+        return (8, 8)
+    else:
+        raise ValueError(f"Unsupported CUDA capability: {major}.{minor}")
 
 
