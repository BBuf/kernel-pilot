    "title": "fix: clamp enable_pdl=True to False on SM < 90 to prevent PDL PTX on Ampere",
    "user": {
      "login": "bkryu",
      "id": 43616432,
      "node_id": "MDQ6VXNlcjQzNjE2NDMy",
      "avatar_url": "https://avatars.githubusercontent.com/u/43616432?v=4",
      "gravatar_id": "",
