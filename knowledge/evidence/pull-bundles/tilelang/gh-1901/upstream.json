    "title": "[BugFix] Add vector type definitions to common.h for CPU codegen",
    "user": {
      "login": "xyyy1420",
      "id": 105905560,
      "node_id": "U_kgDOBk_9mA",
      "avatar_url": "https://avatars.githubusercontent.com/u/105905560?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/xyyy1420",
