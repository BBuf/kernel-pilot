    "title": "[Bugfix] Copy pass_configs dict to prevent mutation across multiple JIT compilations",
    "user": {
      "login": "LeiWang1999",
      "id": 34334180,
      "node_id": "MDQ6VXNlcjM0MzM0MTgw",
      "avatar_url": "https://avatars.githubusercontent.com/u/34334180?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/LeiWang1999",
      "html_url": "https://github.com/LeiWang1999",
      "followers_url": "https://api.github.com/users/LeiWang1999/followers",
      "following_url": "https://api.github.com/users/LeiWang1999/following{/other_user}",
      "gists_url": "https://api.github.com/users/LeiWang1999/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/LeiWang1999/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/LeiWang1999/subscriptions",
      "organizations_url": "https://api.github.com/users/LeiWang1999/orgs",
      "repos_url": "https://api.github.com/users/LeiWang1999/repos",
      "events_url": "https://api.github.com/users/LeiWang1999/events{/privacy}",
      "received_events_url": "https://api.github.com/users/LeiWang1999/received_events",
      "type": "User",
