+        T.launch_thread("blockIdx.x", 1)
+        tx = T.launch_thread("threadIdx.x", 128)
+        for _ in T.serial(4):
+            with T.block():
+                idx = T.alloc_var(T.int32)
+                idx = tx
+                B[tx] = A[idx]
+
+    mod = tvm.IRModule.from_expr(func)
+    mod = tl.transform.LowerOpaqueBlock()(mod)
+    lowered = mod["main"]
+
+    n = _count_attrs(lowered, "lexical_alloc_scope")
