+    num_chunks = _tcgen05_num_smem_chunks(smem_src, 128)
+    if isinstance(tmem_dst, tir.Buffer):
+        tmem_ptr = tmem_dst.data
+    elif isinstance(tmem_dst, (BufferLoad, BufferRegion)):
+        tmem_ptr = tmem_dst.buffer.data
