+        transpose_B,
+        M,
+        N,
+        K,
+        policy,
+        clear_accum,
+        stride_a,
+        stride_b,
+        offset_a,
+        offset_b,
+        1,  # k_pack
+        wg_wait,
+        mbar,
+        C_coords[0],
+        C_coords[1],
+        SFA_arg,  # arg 19
+        SFB_arg,  # arg 20
+        sf_a_id,  # arg 21
+        sf_b_id,  # arg 22
+        annotations=ann,
+    )
