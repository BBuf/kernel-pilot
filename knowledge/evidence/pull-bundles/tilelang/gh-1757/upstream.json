    "title": "[Refactor] Unify the usage of cast-related operators",
    "user": {
      "login": "SiriusNEO",
      "id": 41781658,
      "node_id": "MDQ6VXNlcjQxNzgxNjU4",
      "avatar_url": "https://avatars.githubusercontent.com/u/41781658?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/SiriusNEO",
      "html_url": "https://github.com/SiriusNEO",
      "followers_url": "https://api.github.com/users/SiriusNEO/followers",
      "following_url": "https://api.github.com/users/SiriusNEO/following{/other_user}",
      "gists_url": "https://api.github.com/users/SiriusNEO/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/SiriusNEO/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/SiriusNEO/subscriptions",
      "organizations_url": "https://api.github.com/users/SiriusNEO/orgs",
      "repos_url": "https://api.github.com/users/SiriusNEO/repos",
      "events_url": "https://api.github.com/users/SiriusNEO/events{/privacy}",
      "received_events_url": "https://api.github.com/users/SiriusNEO/received_events",
      "type": "User",
