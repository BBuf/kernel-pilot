+class CumSum2D:
+    """
+    2D cumulative sum operation.
+    Based on tl::CumSum2D from reduce.h
+
+    Template params:
+        threads: Number of threads (must be power of 2, 32-1024)
+        dim: Axis along which to cumsum (0 or 1)
+        reverse: Whether to cumsum in reverse order
+    """
