+
+            if self.reverse:
+                val = _warp_prefix_sum_reverse(val, lane, MASK)
+            else:
+                val = _warp_prefix_sum_forward(val, lane, MASK)
+
+            # Store result - only valid threads write
+            if row_in_col < H and col < W:
+                dst_tensor[idx] = val
+
