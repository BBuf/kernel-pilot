+  <text class="tiny" x="806" y="344">128-word chunk</text>
+  <path class="line dash" d="M976 574 C976 620, 910 632, 840 632"/>
+  <text class="tiny" x="842" y="654">sf_id selects the byte sub-column for this K iteration.</text>
+</svg>
