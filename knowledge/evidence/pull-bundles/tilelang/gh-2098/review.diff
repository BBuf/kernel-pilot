+    .gmem { fill: #e8f4ff; stroke: #6da9ff; }
+    .smem { fill: #fff5df; stroke: #d49a30; }
+    .tmem { fill: #e9f8ef; stroke: #4cae68; }
+    .bar { fill: #f8fafc; stroke: #94a3b8; }
