      "followers_url": "https://api.github.com/users/Achazwl/followers",
      "following_url": "https://api.github.com/users/Achazwl/following{/other_user}",
      "gists_url": "https://api.github.com/users/Achazwl/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/Achazwl/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Achazwl/subscriptions",
      "organizations_url": "https://api.github.com/users/Achazwl/orgs",
      "repos_url": "https://api.github.com/users/Achazwl/repos",
      "events_url": "https://api.github.com/users/Achazwl/events{/privacy}",
      "received_events_url": "https://api.github.com/users/Achazwl/received_events",
