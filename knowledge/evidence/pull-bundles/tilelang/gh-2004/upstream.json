    "title": "fix: fix copy+cast vectorize loop to use wider vector load/store instrcution",
    "user": {
      "login": "Achazwl",
      "id": 23113622,
      "node_id": "MDQ6VXNlcjIzMTEzNjIy",
      "avatar_url": "https://avatars.githubusercontent.com/u/23113622?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/Achazwl",
