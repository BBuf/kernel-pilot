+        ):
+            with T.block("copy"):
+                T.reads(A[i * 4 : i * 4 + 4])
+                T.writes(S[0:4])
+                T.copy(A[i * 4 : i * 4 + 4], S[0:4])
+            with T.block("consume"):
+                T.reads(S[0:4])
