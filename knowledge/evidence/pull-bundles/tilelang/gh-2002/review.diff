+                                      bool *changed) const {
+    if (const auto *let = stmt.as<LetStmtNode>()) {
+      Stmt new_body =
+          RewriteHeadStaticWaitInWrapper(let->body, new_wait_n, changed);
+      if (*changed) {
+        return LetStmt(let->var, let->value, new_body, let->span);
+      }
+      return stmt;
