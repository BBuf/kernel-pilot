+def test_async_pipeline_relaxes_loop_wait_and_splits_trailing_drain():
+    @T.prim_func
+    def before(A: T.Tensor((32,), T.uint8), B: T.Tensor((32,), T.uint8)):
+        S = T.alloc_buffer((4,), dtype=T.uint8, scope="shared")
+        for i in T.serial(
