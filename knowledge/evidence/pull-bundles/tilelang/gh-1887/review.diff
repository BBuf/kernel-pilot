+        T.ptx_commit_group()
+        for i in T.serial(0, 4):
+            # Leading wait inserted by pipelining.
+            T.ptx_wait_group(0)
+            B[i * 4] = S[i * 4]
+            # Prefetch for i+2.
+            T.ptx_cp_async(
+                T.access_ptr(S[(i + 2) * 4], "w", 4),
+                T.access_ptr(A[(i + 2) * 4], "r", 4),
+                4,
