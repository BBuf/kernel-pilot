+                T.ptx_commit_group()
+            with T.block():
+                T.ptx_wait_group(0)
+            with T.block():
+                T.ptx_cp_async(
+                    T.access_ptr(SB[(i + 1) * 4], "w", 4),
+                    T.access_ptr(B[(i + 1) * 4], "r", 4),
