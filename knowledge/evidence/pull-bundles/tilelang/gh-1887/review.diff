+        for k in T.serial(0, 4, annotations={"tl_pipelined_num_stages": T.int32(2)}):
+            # Non-async prefix before the first wait in this loop iteration.
+            tmp[0] = A[k * 4]
+
+            T.ptx_wait_group(0)
