+                    T.access_ptr(A[ko * 4], "r", 4),
+                    4,
+                )
+            T.ptx_commit_group()
+            with T.block("copyB"):
+                T.reads(A[ko * 4 : ko * 4 + 4])
+                T.writes(SB[ko * 4 : ko * 4 + 4])
+                T.ptx_cp_async(
+                    T.access_ptr(SB[ko * 4], "w", 4),
+                    T.access_ptr(A[ko * 4], "r", 4),
+                    4,
+                )
+            T.ptx_commit_group()
+            T.ptx_wait_group(0)
+
+            # Consumer placeholder.
+            with T.block("consume"):
+                T.reads(SA[ko * 4], SB[ko * 4])
+                T.writes(B[ko * 4])
+                B[ko * 4] = SA[ko * 4] + SB[ko * 4]
