+def test_optimize_cp_async_sync_relaxes_loop_head_wait_with_prefetch():
+    @T.prim_func
+    def before(A: T.Tensor((32,), T.uint8), B: T.Tensor((32,), T.uint8)):
+        S = T.alloc_buffer((32,), dtype=T.uint8, scope="shared")
