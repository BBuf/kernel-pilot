+    assert isinstance(ptr.args[0], tir.BufferLoad)
+    assert isinstance(ptr.args[1], tir.IntImm)
+    assert int(ptr.args[1].value) == 16
+    assert isinstance(ptr.args[2], tir.IntImm)
