      "gists_url": "https://api.github.com/users/lhl/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/lhl/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/lhl/subscriptions",
      "organizations_url": "https://api.github.com/users/lhl/orgs",
      "repos_url": "https://api.github.com/users/lhl/repos",
      "events_url": "https://api.github.com/users/lhl/events{/privacy}",
      "received_events_url": "https://api.github.com/users/lhl/received_events",
      "type": "User",
