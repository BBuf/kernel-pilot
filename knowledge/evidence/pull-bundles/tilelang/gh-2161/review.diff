+        inst_m_idx : int
+            M-dimension atom index (0 .. tcgen05_num_inst_m - 1).
+        inst_n_idx : int
+            N-dimension atom index (0 .. tcgen05_num_inst_n - 1).
+        ki : int
+            K-dimension atom index (0 .. tcgen05_num_k_atoms - 1).
+        a_params : TCGEN05DescriptorParams
