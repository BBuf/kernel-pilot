+        atom_m_per_cta = atom_m // 2 if enable_2cta else atom_m
+        n_dim = self.block_col_warps * self.warp_col_tiles
+        n_dim_per_cta = n_dim // 2 if enable_2cta else n_dim
+        m_dim = self.block_row_warps * self.warp_row_tiles
