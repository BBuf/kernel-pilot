+  bool ContainsTmaLoadStmt(const Stmt &stmt) {
+    bool found = false;
+    PostOrderVisit(stmt, [&](const ObjectRef &node) {
+      if (auto *call = node.as<CallNode>()) {
+        if (call->op.same_as(tma_load()) ||
+            call->op.same_as(tma_load_im2col())) {
+          found = true;
+        }
+      }
+    });
+    return found;
+  }
