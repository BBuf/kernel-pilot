    "title": "[Bugfix] Enable `.shared::cta` in TMA copy paths only on CUDA 12.8+",
    "user": {
      "login": "ColmaLiu",
      "id": 176567134,
      "node_id": "U_kgDOCoYzXg",
      "avatar_url": "https://avatars.githubusercontent.com/u/176567134?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/ColmaLiu",
      "html_url": "https://github.com/ColmaLiu",
      "followers_url": "https://api.github.com/users/ColmaLiu/followers",
      "following_url": "https://api.github.com/users/ColmaLiu/following{/other_user}",
      "gists_url": "https://api.github.com/users/ColmaLiu/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/ColmaLiu/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/ColmaLiu/subscriptions",
      "organizations_url": "https://api.github.com/users/ColmaLiu/orgs",
      "repos_url": "https://api.github.com/users/ColmaLiu/repos",
