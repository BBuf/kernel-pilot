+      return TmaProducerWaitPair{
+          BlockRealize(realize->iter_values, realize->predicate,
+                       producer_block),
+          BlockRealize(realize->iter_values, realize->predicate, wait_block)};
+    }
+    return std::nullopt;
+  }
