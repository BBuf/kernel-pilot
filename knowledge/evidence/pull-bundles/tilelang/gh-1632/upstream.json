    "title": "[Refactor] Unify @jit and @lazy_jit into a single @jit decorator",
    "user": {
      "login": "LeiWang1999",
      "id": 34334180,
      "node_id": "MDQ6VXNlcjM0MzM0MTgw",
      "avatar_url": "https://avatars.githubusercontent.com/u/34334180?v=4",
      "gravatar_id": "",
