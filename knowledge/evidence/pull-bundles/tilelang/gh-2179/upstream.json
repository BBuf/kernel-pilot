      "html_url": "https://github.com/zihaomu",
      "followers_url": "https://api.github.com/users/zihaomu/followers",
      "following_url": "https://api.github.com/users/zihaomu/following{/other_user}",
      "gists_url": "https://api.github.com/users/zihaomu/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/zihaomu/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/zihaomu/subscriptions",
      "organizations_url": "https://api.github.com/users/zihaomu/orgs",
      "repos_url": "https://api.github.com/users/zihaomu/repos",
      "events_url": "https://api.github.com/users/zihaomu/events{/privacy}",
      "received_events_url": "https://api.github.com/users/zihaomu/received_events",
      "type": "User",
