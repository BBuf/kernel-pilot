+    return lambda f: f
+
+
+def LowerL2Persistent():
+    """LowerL2Persistent"""
+    return _ffi_api.LowerL2Persistent()  # type: ignore
+
+
+def PersistThreadblock():
+    """PersistThreadblock"""
+    return _ffi_api.PersistThreadblock()  # type: ignore
+
+
+__all__ = [
+    "LowerHopperIntrin",
+    "LowerL2Persistent",
