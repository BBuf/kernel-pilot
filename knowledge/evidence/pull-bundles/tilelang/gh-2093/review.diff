+# breaks resource paths when helpers are invoked from included Find modules
+# (e.g. cmake/pypi-z3/FindZ3.cmake).
+set(TILELANG_CMAKELISTS_DIR "${CMAKE_CURRENT_LIST_DIR}")
+
