+def prepend_dll_search_path(paths: list[str]) -> None:
+    """Prepend ``paths`` to ``%PATH%`` on Windows, skipping entries already present.
+
+    Used by Windows DLL discovery: PATH is consulted by ``LoadLibrary`` and by
