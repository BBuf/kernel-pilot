      "starred_url": "https://api.github.com/users/hammersam/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/hammersam/subscriptions",
      "organizations_url": "https://api.github.com/users/hammersam/orgs",
      "repos_url": "https://api.github.com/users/hammersam/repos",
