    "locked": false,
    "title": "Unified packed x2 intrinsics with multi-dtype support and bug fixes",
    "user": {
      "login": "bucket-xv",
      "id": 122071158,
      "node_id": "U_kgDOB0aodg",
      "avatar_url": "https://avatars.githubusercontent.com/u/122071158?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/bucket-xv",
      "html_url": "https://github.com/bucket-xv",
      "followers_url": "https://api.github.com/users/bucket-xv/followers",
      "following_url": "https://api.github.com/users/bucket-xv/following{/other_user}",
      "gists_url": "https://api.github.com/users/bucket-xv/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/bucket-xv/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/bucket-xv/subscriptions",
      "organizations_url": "https://api.github.com/users/bucket-xv/orgs",
      "repos_url": "https://api.github.com/users/bucket-xv/repos",
      "events_url": "https://api.github.com/users/bucket-xv/events{/privacy}",
      "received_events_url": "https://api.github.com/users/bucket-xv/received_events",
