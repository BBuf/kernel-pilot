+    ) = recompute_w_u_fwd(
+        k=K,
+        v=V,
+        beta=Beta,
+        gk=G,
+        A=A,
+    )
+
+    block_S = chunk_size
+    kernel = tilelang_recompute_w_u_fwd(
+        B,
+        S,
+        H,
+        DK,
+        DV,
+        input_dtype,
+        output_dtype,
+        gate_dtype,
+        accum_dtype,
+        chunk_size,
+        use_qg,
+        use_kg,
+        block_S=block_S,
