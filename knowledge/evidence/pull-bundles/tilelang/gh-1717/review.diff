+def test_e2e_load_global_store_global():
+    """End-to-end test that ldg/stg intrinsics work correctly when enabled."""
+    import torch
+
+    @tilelang.jit(pass_configs={PassConfigKey.TL_ENABLE_LOWER_LDGSTG: True})
+    def copy_kernel(X, Y):
