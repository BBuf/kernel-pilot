+        Y: T.Tensor[[N], T.float32]
+
+        with T.Kernel(N // 4, threads=32) as pid:
+            for j in T.vectorized(4):
+                Y[pid * 4 + j] = T.if_then_else(pid < N // 8, X[pid * 4 + j], T.float32(0))
