+            logger.warning(
+                "No valid benchmark devices resolved for multi-GPU benchmark. Falling back to single-device benchmark on cuda:%s.",
+                current_device,
+            )
+            return False, single_device
+
+        return len(valid_devices) > 1, valid_devices
