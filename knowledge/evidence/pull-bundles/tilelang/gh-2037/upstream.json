      "following_url": "https://api.github.com/users/kurisu6912/following{/other_user}",
      "gists_url": "https://api.github.com/users/kurisu6912/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/kurisu6912/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/kurisu6912/subscriptions",
      "organizations_url": "https://api.github.com/users/kurisu6912/orgs",
      "repos_url": "https://api.github.com/users/kurisu6912/repos",
      "events_url": "https://api.github.com/users/kurisu6912/events{/privacy}",
