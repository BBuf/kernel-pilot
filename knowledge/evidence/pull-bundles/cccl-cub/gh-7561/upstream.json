    "locked": false,
    "title": "Remove recursion from __internal_is_address_from",
    "user": {
      "login": "dkolsen-pgi",
      "id": 26287601,
      "node_id": "MDQ6VXNlcjI2Mjg3NjAx",
      "avatar_url": "https://avatars.githubusercontent.com/u/26287601?v=4",
      "gravatar_id": "",
