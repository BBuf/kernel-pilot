+//===----------------------------------------------------------------------===//
+
+// <cuda/std/__simd_>
+
+// [simd.mask.reductions], reduce_max_index
+//
+// template<size_t Bytes, class Abi>
+//   constexpr simd-size-type reduce_max_index(const basic_mask<Bytes, Abi>&);
+//
+// constexpr simd-size-type reduce_max_index(same_as<bool> auto);
+
+#include <cuda/std/__simd_>
+#include <cuda/std/cassert>
+#include <cuda/std/type_traits>
+
+#include "../simd_test_utils.h"
+#include "test_macros.h"
+
+template <int Bytes, int N>
+TEST_FUNC constexpr void test_reduce_max_index()
+{
+  using Mask = simd::basic_mask<Bytes, simd::fixed_size<N>>;
+  assert(simd::reduce_max_index(Mask(true)) == N - 1);
+
+  if constexpr (N > 1)
+  {
+    Mask first_only(is_index<0>{});
+    assert(simd::reduce_max_index(first_only) == 0);
+
+    Mask even(is_even{});
+    assert(simd::reduce_max_index(even) == (N - 1) / 2 * 2);
+  }
+
+  if constexpr (N >= 4)
+  {
+    Mask lower_half(is_less_than_index<N / 2>{});
+    assert(simd::reduce_max_index(lower_half) == N / 2 - 1);
+  }
+}
+
+TEST_FUNC constexpr void test_reduce_max_index_scalar_bool()
+{
+  assert(simd::reduce_max_index(true) == 0);
+}
+
+template <int Bytes>
+TEST_FUNC constexpr void test_bytes()
+{
+  test_reduce_max_index<Bytes, 1>();
+  test_reduce_max_index<Bytes, 4>();
+}
+
+TEST_FUNC constexpr bool test()
+{
+  test_bytes<1>();
+  test_bytes<2>();
+  test_bytes<4>();
+  test_bytes<8>();
+#if _CCCL_HAS_INT128()
+  test_bytes<16>();
+#endif
+  test_reduce_max_index_scalar_bool();
+  return true;
+}
+
+int main(int, char**)
+{
+  assert(test());
+  static_assert(test());
+  return 0;
+}
diff --git a/libcudacxx/test/libcudacxx/std/numerics/simd/simd.reductions/reduce_min.pass.cpp b/libcudacxx/test/libcudacxx/std/numerics/simd/simd.reductions/reduce_min.pass.cpp
