    "title": "[STF] Fix stream_ctx under CUDA graph capture",
    "user": {
      "login": "caugonnet",
      "id": 158148890,
      "node_id": "U_kgDOCW0pGg",
      "avatar_url": "https://avatars.githubusercontent.com/u/158148890?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/caugonnet",
      "html_url": "https://github.com/caugonnet",
      "followers_url": "https://api.github.com/users/caugonnet/followers",
      "following_url": "https://api.github.com/users/caugonnet/following{/other_user}",
      "gists_url": "https://api.github.com/users/caugonnet/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/caugonnet/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/caugonnet/subscriptions",
      "organizations_url": "https://api.github.com/users/caugonnet/orgs",
      "repos_url": "https://api.github.com/users/caugonnet/repos",
      "events_url": "https://api.github.com/users/caugonnet/events{/privacy}",
