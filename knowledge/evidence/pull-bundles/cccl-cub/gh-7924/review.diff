diff --git a/libcudacxx/test/libcudacxx/std/algorithms/alg.modifying/alg.reverse/pstl_reverse.cu b/libcudacxx/test/libcudacxx/std/algorithms/alg.modifying/alg.reverse/pstl_reverse.cu
