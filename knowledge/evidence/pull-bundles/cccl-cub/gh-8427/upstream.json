    "title": "[thrust] Single-pass `is_partitioned` via adjacent zip_iterator",
    "user": {
      "login": "edenfunf",
      "id": 146086744,
      "node_id": "U_kgDOCLUbWA",
      "avatar_url": "https://avatars.githubusercontent.com/u/146086744?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/edenfunf",
      "html_url": "https://github.com/edenfunf",
      "followers_url": "https://api.github.com/users/edenfunf/followers",
      "following_url": "https://api.github.com/users/edenfunf/following{/other_user}",
      "gists_url": "https://api.github.com/users/edenfunf/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/edenfunf/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/edenfunf/subscriptions",
      "organizations_url": "https://api.github.com/users/edenfunf/orgs",
      "repos_url": "https://api.github.com/users/edenfunf/repos",
      "events_url": "https://api.github.com/users/edenfunf/events{/privacy}",
