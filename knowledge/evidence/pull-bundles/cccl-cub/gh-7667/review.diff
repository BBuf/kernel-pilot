+          14,
+          BLOCK_LOAD_DIRECT,
+          LOAD_CA,
+          BLOCK_SCAN_WARP_SCANS,
+          {delay_constructor_kind::exponential_backon, 468, 300}};
+      }
+      if (key_size == 2)
+      {
+        return rle_encode_policy{
+          224,
+          14,
+          BLOCK_LOAD_DIRECT,
+          LOAD_DEFAULT,
+          BLOCK_SCAN_WARP_SCANS,
