    "locked": false,
    "title": "Recover `warp_shuffle` original behavior (revert #8210)",
    "user": {
      "login": "fbusato",
      "id": 50413820,
      "node_id": "MDQ6VXNlcjUwNDEzODIw",
      "avatar_url": "https://avatars.githubusercontent.com/u/50413820?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/fbusato",
      "html_url": "https://github.com/fbusato",
      "followers_url": "https://api.github.com/users/fbusato/followers",
      "following_url": "https://api.github.com/users/fbusato/following{/other_user}",
      "gists_url": "https://api.github.com/users/fbusato/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/fbusato/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/fbusato/subscriptions",
      "organizations_url": "https://api.github.com/users/fbusato/orgs",
      "repos_url": "https://api.github.com/users/fbusato/repos",
      "events_url": "https://api.github.com/users/fbusato/events{/privacy}",
