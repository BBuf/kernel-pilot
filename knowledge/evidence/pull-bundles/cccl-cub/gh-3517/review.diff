+#if IPT == 1
+C2H_TEST("Vectorized block load with const and non-const datatype and different alignment cases",
+         "[load][block]",
+         c2h::type_list<const int*, int*>)
+{
+  using type           = int;
+  using input_ptr_type = c2h::get<0, TestType>;
