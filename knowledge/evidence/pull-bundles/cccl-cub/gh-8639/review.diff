+      h_input.begin() + h_offsets[segment_id + 1],
+      h_expected.begin() + h_offsets[segment_id],
+      op,
+      h_init);
+
+    for (offset_t offset = h_offsets[segment_id]; offset < h_offsets[segment_id + 1]; ++offset)
