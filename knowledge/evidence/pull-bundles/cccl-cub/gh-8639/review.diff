+  const unsigned int num_items         = num_segments * items_per_segment;
+
+  c2h::host_vector<offset_t> h_offsets(num_segments + 1);
+  for (unsigned i = 0; i <= num_segments; ++i)
+  {
+    h_offsets[i] = i * items_per_segment;
+  }
