+  template <typename ScannerT,
+            typename ItemTy,
+            typename InitValueTy,
+            typename ScanOpTy,
+            bool IsInclusive = is_inclusive,
+            bool HasInit     = has_init>
+  _CCCL_DEVICE _CCCL_FORCEINLINE void scan_first_tile(
+    ScannerT& scanner,
+    ItemTy (&items)[items_per_thread],
+    InitValueTy init_value,
+    ScanOpTy scan_op,
