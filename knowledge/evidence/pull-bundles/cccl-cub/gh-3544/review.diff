+#  endif
+#  if (_NV_TARGET___NV_PROVIDES_SM_100)
+#    define _NV_TARGET_BOOL___NV_PROVIDES_SM_100 1
+#  else
+#    define _NV_TARGET_BOOL___NV_PROVIDES_SM_100 0
+#  endif
+
