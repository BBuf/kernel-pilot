    "title": "`cuda.cccl.parallel`: Expose \"well-known\" operations to Python",
    "user": {
      "login": "shwina",
      "id": 3190405,
      "node_id": "MDQ6VXNlcjMxOTA0MDU=",
      "avatar_url": "https://avatars.githubusercontent.com/u/3190405?v=4",
