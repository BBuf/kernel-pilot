+constexpr _CCCL_HOST_DEVICE bool is_arithmetic_type(type_t type)
+{
+  switch (type)
+  {
+    case type_t::boolean:
+    case type_t::int8:
+    case type_t::int16:
+    case type_t::int32:
+    case type_t::int64:
+    case type_t::int128:
+    case type_t::uint8:
+    case type_t::uint16:
+    case type_t::uint32:
+    case type_t::uint64:
+    case type_t::uint128:
+    case type_t::float32:
+    case type_t::float64:
+      return true;
+    case type_t::other:
+      return false;
+  }
+
+  return false;
+}
