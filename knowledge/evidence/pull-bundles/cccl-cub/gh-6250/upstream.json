    "title": "Replace inline PTX by cuda::ptx in cuda::barrier<thread_scope_block>",
    "user": {
      "login": "bernhardmgruber",
      "id": 1224051,
      "node_id": "MDQ6VXNlcjEyMjQwNTE=",
