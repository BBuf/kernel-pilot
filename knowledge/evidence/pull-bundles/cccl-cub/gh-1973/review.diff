+    kernel[1, 32](d_input, d_output)
+    cuda.synchronize()
+
+    output = d_output.copy_to_host()
+    reference = np.cumsum(h_input) - h_input
+    for i in range(32):
+        assert output[i] == reference[i]
+
+    sig = (T[::1], T[::1])
+    sass = kernel.inspect_sass(sig)
+
+    assert 'LDL' not in sass
+    assert 'STL' not in sass
