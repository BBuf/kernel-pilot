+      result.begin(),
+      block_size_check,
+      env));
+
+  c2h::device_vector<int> expected{0, 0, 2, 3, 3, 4, 5};
+  REQUIRE(result == expected);
+  REQUIRE(d_block_size[0] == target_block_size);
