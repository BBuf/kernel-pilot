    "title": "[c2h] Make catch macros work on device",
    "user": {
      "login": "davebayer",
      "id": 48736217,
      "node_id": "MDQ6VXNlcjQ4NzM2MjE3",
      "avatar_url": "https://avatars.githubusercontent.com/u/48736217?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/davebayer",
      "html_url": "https://github.com/davebayer",
      "followers_url": "https://api.github.com/users/davebayer/followers",
      "following_url": "https://api.github.com/users/davebayer/following{/other_user}",
      "gists_url": "https://api.github.com/users/davebayer/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/davebayer/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/davebayer/subscriptions",
      "organizations_url": "https://api.github.com/users/davebayer/orgs",
      "repos_url": "https://api.github.com/users/davebayer/repos",
      "events_url": "https://api.github.com/users/davebayer/events{/privacy}",
