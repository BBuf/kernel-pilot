+                         agent_batched_topk_worker_per_segment_policy<256, 4, default_load_alg, default_store_alg>,
+                         agent_batched_topk_worker_per_segment_policy<128, 2, default_load_alg, default_store_alg>>;
+  };
+
+  using max_policy = Policy900;
+};
