+- C++ uses cuda::minimum<> which CUB recognizes for optimized code paths (DPX on Hopper+)
+- int128 and complex32 are not supported by cupy
+"""
+
+import sys
+from pathlib import Path
+
+sys.path.insert(0, str(Path(__file__).parent.parent))
+
+import cupy as cp
