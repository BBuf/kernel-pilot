+  cuda::mr::__shared_block_ptr<trivial_payload> a_copy(a); // NOLINT(performance-unnecessary-copy-initialization)
+  cuda::mr::__shared_block_ptr<trivial_payload> null;
+
+  CHECK(a == a);
+  CHECK(a == a_copy);
+  CHECK(a != b);
+  CHECK(a != null);
