+
+from triton_state_update import hedgehog_step, hedgehog_step_ref
+
+
+def step_benchmark(dt, device='cuda'):
+    num_iters = 10
+    
+    methods = {
+        'Pure PyTorch': hedgehog_step_ref, 
+        'Triton Kernel': hedgehog_step,
