+        kv_state_t = kv_state.transpose(1,2).contiguous() # We prefer the other order for iteration.
+
+        for name, fn, in methods.items():
+            torch.cuda.synchronize()
+            t0 = time.time()
+            
+            outs = [
+                fn(kv_state=kv_state, k_state=k_state, v=v, k=k, q=q)
