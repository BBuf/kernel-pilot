    "title": "Fix TRT-LLM MLA backend applying k_scale to BF16 KV cache in BMM1",
    "user": {
      "login": "debo3",
      "id": 128179937,
      "node_id": "U_kgDOB6Pe4Q",
      "avatar_url": "https://avatars.githubusercontent.com/u/128179937?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/debo3",
      "html_url": "https://github.com/debo3",
      "followers_url": "https://api.github.com/users/debo3/followers",
      "following_url": "https://api.github.com/users/debo3/following{/other_user}",
      "gists_url": "https://api.github.com/users/debo3/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/debo3/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/debo3/subscriptions",
      "organizations_url": "https://api.github.com/users/debo3/orgs",
      "repos_url": "https://api.github.com/users/debo3/repos",
      "events_url": "https://api.github.com/users/debo3/events{/privacy}",
      "received_events_url": "https://api.github.com/users/debo3/received_events",
