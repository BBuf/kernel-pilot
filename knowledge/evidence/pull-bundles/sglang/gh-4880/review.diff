+RequestPoolType = Dict[int, Tuple[npt.NDArray[np.int64], Optional[int]]]
+WaitingPoolType = Dict[
+    int, Tuple[str, list[int], npt.NDArray[np.int64], list[int], int]
+]
+KVSENDER_POLLING_PORT = 17788
+KVRECEIVER_POLLING_PORT = 27788
