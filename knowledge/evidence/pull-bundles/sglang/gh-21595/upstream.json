      "starred_url": "https://api.github.com/users/JustinTong0323/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/JustinTong0323/subscriptions",
      "organizations_url": "https://api.github.com/users/JustinTong0323/orgs",
      "repos_url": "https://api.github.com/users/JustinTong0323/repos",
      "events_url": "https://api.github.com/users/JustinTong0323/events{/privacy}",
      "received_events_url": "https://api.github.com/users/JustinTong0323/received_events",
