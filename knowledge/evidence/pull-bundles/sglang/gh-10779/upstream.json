      "contents_url": "https://api.github.com/repos/sgl-project/sglang/contents/python%2Fsglang%2Fsrt%2Fmodels%2Fdeepseek_v2.py?ref=9f4f840ffcc5de81ca3040dd4bdd9dcd5c3768a7",
      "patch": "@@ -1399,7 +1399,10 @@ def _fuse_rope_for_trtllm_mla(self, forward_batch: ForwardBatch) -> bool:\n         \"\"\"\n         return (\n             self.current_attention_backend == \"trtllm_mla\"\n-            and forward_batch.forward_mode.is_decode_or_idle()\n+            and (\n+                forward_batch.forward_mode.is_decode_or_idle()\n+                or forward_batch.forward_mode.is_target_verify()\n+            )\n             and forward_batch.attn_backend.data_type == torch.float8_e4m3fn\n         )\n "
