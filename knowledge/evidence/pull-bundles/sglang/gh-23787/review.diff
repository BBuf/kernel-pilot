@@ -0,0 +1,27 @@
+from sglang.srt.function_call.deepseekv32_detector import DeepSeekV32Detector
+
+
+class DeepSeekV4Detector(DeepSeekV32Detector):
+    """
+    Detector for DeepSeek V4 DSML tool-call format.
+
+    Identical to V3.2 except the outer block wrapper is
+    ``<ÔĹúDSMLÔĹútool_calls>...</ÔĹúDSMLÔĹútool_calls>`` instead of
+    ``<ÔĹúDSMLÔĹúfunction_calls>...</ÔĹúDSMLÔĹúfunction_calls>``. The inner
+    ``<ÔĹúDSMLÔĹúinvoke>`` / ``<ÔĹúDSMLÔĹúparameter>`` shape is unchanged.
+
+    Example (XML parameters):
+    ```
+    <ÔĹúDSMLÔĹútool_calls>
+        <ÔĹúDSMLÔĹúinvoke name="get_weather">
+        <ÔĹúDSMLÔĹúparameter name="city" string="true">San Francisco</ÔĹúDSMLÔĹúparameter>
+        </ÔĹúDSMLÔĹúinvoke>
+    </ÔĹúDSMLÔĹútool_calls>
+    ```
+    """
+
+    def __init__(self):
+        super().__init__()
+        self.bot_token = "<ÔĹúDSMLÔĹútool_calls>"
+        self.eot_token = "</ÔĹúDSMLÔĹútool_calls>"
+        self.function_calls_regex = r"<ÔĹúDSMLÔĹútool_calls>(.*?)</ÔĹúDSMLÔĹútool_calls>"
