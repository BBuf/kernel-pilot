+        freqs_cis = self.freqs_cis[(seq_lens - 1) // self.ratio * self.ratio]
+        self.print_tensor(freqs_cis, "freqs_cis")
+        apply_rotary_emb_triton(kv_compressed[..., -self.rope_head_dim :], freqs_cis)
