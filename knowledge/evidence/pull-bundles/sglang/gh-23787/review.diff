+            offsets = torch.arange(1, draft_tokens + 1, device=seq_lens.device)
+            seq_lens_2d = seq_lens[:, None] + offsets[None, :]
+            seq_lens = seq_lens_2d.view(-1)
+            req_pool_indices = req_pool_indices.repeat_interleave(draft_tokens)
