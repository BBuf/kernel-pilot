+        quant_group_size, scale_ue8m0, is_arch_support_pdl(), apply_swiglu_limit
+    )
+    return load_jit(
+        make_name("silu_mul_quant"),
+        *args,
+        cuda_files=["deepseek_v4/silu_and_mul_masked_post_quant.cuh"],
