+    ) -> Tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
+        if TYPE_CHECKING:
+            assert isinstance(self, CompressorBackend)
+
+        q = c4_indexer.compute_q(q_lora, positions=positions)
