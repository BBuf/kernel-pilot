+        skip_prefill: bool = False,
+        speculative_step_id=0,
+        topk=0,
+        speculative_num_steps=0,
+    ):
+        super().__init__()
+        self.device = torch.device(model_runner.device)  # type: ignore
+        head_dim = model_runner.model_config.head_dim
