    "locked": false,
    "title": "Fix flashinfer cutlass MoE output shape for non-FP4-packed inputs",
    "user": {
      "login": "alisonshao",
      "id": 54658187,
      "node_id": "MDQ6VXNlcjU0NjU4MTg3",
      "avatar_url": "https://avatars.githubusercontent.com/u/54658187?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/alisonshao",
      "html_url": "https://github.com/alisonshao",
      "followers_url": "https://api.github.com/users/alisonshao/followers",
      "following_url": "https://api.github.com/users/alisonshao/following{/other_user}",
      "gists_url": "https://api.github.com/users/alisonshao/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/alisonshao/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/alisonshao/subscriptions",
      "organizations_url": "https://api.github.com/users/alisonshao/orgs",
      "repos_url": "https://api.github.com/users/alisonshao/repos",
      "events_url": "https://api.github.com/users/alisonshao/events{/privacy}",
