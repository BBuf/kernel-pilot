    "title": "DeepSeek-R1-0528-w4a8: DeepEP Low Latency Dispatch Adopts FP8 Communication",
    "user": {
      "login": "xieminghe1",
      "id": 141820649,
      "node_id": "U_kgDOCHQC6Q",
      "avatar_url": "https://avatars.githubusercontent.com/u/141820649?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/xieminghe1",
      "html_url": "https://github.com/xieminghe1",
      "followers_url": "https://api.github.com/users/xieminghe1/followers",
      "following_url": "https://api.github.com/users/xieminghe1/following{/other_user}",
      "gists_url": "https://api.github.com/users/xieminghe1/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/xieminghe1/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/xieminghe1/subscriptions",
      "organizations_url": "https://api.github.com/users/xieminghe1/orgs",
      "repos_url": "https://api.github.com/users/xieminghe1/repos",
      "events_url": "https://api.github.com/users/xieminghe1/events{/privacy}",
      "received_events_url": "https://api.github.com/users/xieminghe1/received_events",
      "type": "User",
