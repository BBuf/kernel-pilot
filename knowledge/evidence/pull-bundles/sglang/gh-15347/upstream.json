      "gists_url": "https://api.github.com/users/leejnau/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/leejnau/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/leejnau/subscriptions",
      "organizations_url": "https://api.github.com/users/leejnau/orgs",
      "repos_url": "https://api.github.com/users/leejnau/repos",
      "events_url": "https://api.github.com/users/leejnau/events{/privacy}",
