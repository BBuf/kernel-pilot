    "title": "Use dsv3 optimized routing `fused_topk_deepseek` instead of `moe_fused_gate`",
    "user": {
      "login": "leejnau",
      "id": 3129145,
      "node_id": "MDQ6VXNlcjMxMjkxNDU=",
