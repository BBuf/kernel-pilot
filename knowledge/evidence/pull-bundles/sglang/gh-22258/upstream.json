    "title": "[AMD][HIP] NSA: bf16 passthrough from RMSNorm to eliminate FP8 dequantization",
    "user": {
      "login": "Jacob0226",
      "id": 161288656,
      "node_id": "U_kgDOCZ0R0A",
      "avatar_url": "https://avatars.githubusercontent.com/u/161288656?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/Jacob0226",
      "html_url": "https://github.com/Jacob0226",
      "followers_url": "https://api.github.com/users/Jacob0226/followers",
      "following_url": "https://api.github.com/users/Jacob0226/following{/other_user}",
      "gists_url": "https://api.github.com/users/Jacob0226/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/Jacob0226/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Jacob0226/subscriptions",
      "organizations_url": "https://api.github.com/users/Jacob0226/orgs",
      "repos_url": "https://api.github.com/users/Jacob0226/repos",
      "events_url": "https://api.github.com/users/Jacob0226/events{/privacy}",
      "received_events_url": "https://api.github.com/users/Jacob0226/received_events",
      "type": "User",
