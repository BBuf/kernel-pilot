      "subscriptions_url": "https://api.github.com/users/MikkoParkkola/subscriptions",
      "organizations_url": "https://api.github.com/users/MikkoParkkola/orgs",
      "repos_url": "https://api.github.com/users/MikkoParkkola/repos",
