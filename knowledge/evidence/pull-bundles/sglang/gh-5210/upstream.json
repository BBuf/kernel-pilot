es SM>=90. \"\n                 \"Please use `--attention-backend flashinfer`.\"\n             )\n-            logger.warning(\n-                \"FlashAttention v3 Backend is in Beta. FP8 is not supported.\"\n-            )\n             from sglang.srt.layers.attention.flashattention_backend import (\n                 FlashAttentionBackend,\n             )"
