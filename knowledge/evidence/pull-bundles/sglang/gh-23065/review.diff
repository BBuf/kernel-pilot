+    parser.add_argument(
+        "--total-tokens",
+        type=int,
+        default=30720,
+        help="Total tokens for benchmarking (default: 30720 = 2 reqs x 15360)",
+    )
+    args = parser.parse_args()
+
+    if not args.model and not args.hidden_size:
+        parser.error("Either --model or --hidden-size is required")
+
+    main(args)
