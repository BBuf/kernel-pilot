      "sha": "c0e72c2555b80e0a8f6bba046db63ffefe6d9208",
      "filename": "python/sglang/jit_kernel/include/sgl_kernel/vec.cuh",
      "status": "added",
      "additions": 89,
      "deletions": 0,
