      "filename": "python/sglang/srt/layers/quantization/fp8.py",
      "status": "modified",
      "additions": 27,
      "deletions": 7,
      "changes": 34,
      "blob_url": "https://github.com/sgl-project/sglang/blob/23920af2441b38dc7fb42e73222a7469610250b9/python%2Fsglang%2Fsrt%2Flayers%2Fquantization%2Ffp8.py",
