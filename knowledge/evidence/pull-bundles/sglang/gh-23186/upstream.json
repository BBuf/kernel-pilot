    "title": "[AMD] Fused qk rmsnorm bf16 for amd/Kimi-K2.5-MXFP4",
    "user": {
      "login": "akao-amd",
      "id": 231193780,
      "node_id": "U_kgDODce8tA",
      "avatar_url": "https://avatars.githubusercontent.com/u/231193780?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/akao-amd",
