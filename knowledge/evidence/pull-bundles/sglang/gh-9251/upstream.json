    "title": "feat: Add Triton fallback option and SM120 MoE configs for FP8 models",
    "user": {
      "login": "voipmonitor",
      "id": 7045031,
      "node_id": "MDQ6VXNlcjcwNDUwMzE=",
      "avatar_url": "https://avatars.githubusercontent.com/u/7045031?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/voipmonitor",
      "html_url": "https://github.com/voipmonitor",
      "followers_url": "https://api.github.com/users/voipmonitor/followers",
      "following_url": "https://api.github.com/users/voipmonitor/following{/other_user}",
      "gists_url": "https://api.github.com/users/voipmonitor/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/voipmonitor/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/voipmonitor/subscriptions",
      "organizations_url": "https://api.github.com/users/voipmonitor/orgs",
      "repos_url": "https://api.github.com/users/voipmonitor/repos",
      "events_url": "https://api.github.com/users/voipmonitor/events{/privacy}",
      "received_events_url": "https://api.github.com/users/voipmonitor/received_events",
      "type": "User",
