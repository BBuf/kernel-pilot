    "title": "fix: TRT-LLM MHA CUDA illegal address with EAGLE v2 + DP attention",
    "user": {
      "login": "Kangyan-Zhou",
      "id": 12483620,
      "node_id": "MDQ6VXNlcjEyNDgzNjIw",
      "avatar_url": "https://avatars.githubusercontent.com/u/12483620?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/Kangyan-Zhou",
