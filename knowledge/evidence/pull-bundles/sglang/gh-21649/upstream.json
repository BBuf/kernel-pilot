      "starred_url": "https://api.github.com/users/Kangyan-Zhou/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Kangyan-Zhou/subscriptions",
      "organizations_url": "https://api.github.com/users/Kangyan-Zhou/orgs",
      "repos_url": "https://api.github.com/users/Kangyan-Zhou/repos",
      "events_url": "https://api.github.com/users/Kangyan-Zhou/events{/privacy}",
      "received_events_url": "https://api.github.com/users/Kangyan-Zhou/received_events",
