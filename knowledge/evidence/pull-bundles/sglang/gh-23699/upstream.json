    "title": "[NSA] Fall back to fast_hadamard_transform when sgl_kernel lacks the symbol",
    "user": {
      "login": "Fridge003",
      "id": 56809903,
      "node_id": "MDQ6VXNlcjU2ODA5OTAz",
      "avatar_url": "https://avatars.githubusercontent.com/u/56809903?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/Fridge003",
      "html_url": "https://github.com/Fridge003",
      "followers_url": "https://api.github.com/users/Fridge003/followers",
      "following_url": "https://api.github.com/users/Fridge003/following{/other_user}",
      "gists_url": "https://api.github.com/users/Fridge003/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/Fridge003/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Fridge003/subscriptions",
      "organizations_url": "https://api.github.com/users/Fridge003/orgs",
      "repos_url": "https://api.github.com/users/Fridge003/repos",
