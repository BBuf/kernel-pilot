    "title": "[Fix][Qwen3.5] Fix KV cache slice transfer for GQA models with replicated KV heads",
    "user": {
      "login": "YAMY1234",
      "id": 74099316,
      "node_id": "MDQ6VXNlcjc0MDk5MzE2",
      "avatar_url": "https://avatars.githubusercontent.com/u/74099316?v=4",
