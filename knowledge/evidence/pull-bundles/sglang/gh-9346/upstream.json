    "locked": false,
    "title": "Fix FP4 inference corruption issue in glm4.5-air model",
    "user": {
      "login": "Azure-Tang",
      "id": 50126533,
      "node_id": "MDQ6VXNlcjUwMTI2NTMz",
      "avatar_url": "https://avatars.githubusercontent.com/u/50126533?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/Azure-Tang",
      "html_url": "https://github.com/Azure-Tang",
      "followers_url": "https://api.github.com/users/Azure-Tang/followers",
      "following_url": "https://api.github.com/users/Azure-Tang/following{/other_user}",
      "gists_url": "https://api.github.com/users/Azure-Tang/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/Azure-Tang/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Azure-Tang/subscriptions",
      "organizations_url": "https://api.github.com/users/Azure-Tang/orgs",
      "repos_url": "https://api.github.com/users/Azure-Tang/repos",
      "events_url": "https://api.github.com/users/Azure-Tang/events{/privacy}",
      "received_events_url": "https://api.github.com/users/Azure-Tang/received_events",
      "type": "User",
