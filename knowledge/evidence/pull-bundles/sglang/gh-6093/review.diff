-"""Cutlass MoE kernel."""
+"""CUTLASS based Fused MoE kernels."""
 
 import functools
 import json
@@ -14,8 +14,10 @@
 if _is_cuda:
     import sgl_kernel
     from sgl_kernel import (
+        cutlass_fp4_group_mm,
