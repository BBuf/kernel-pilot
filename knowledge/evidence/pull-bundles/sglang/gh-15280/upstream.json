    "title": "[NVIDIA] Fixes for NVFP4 all-gather with spec decoding",
    "user": {
      "login": "trevor-m",
      "id": 12981474,
      "node_id": "MDQ6VXNlcjEyOTgxNDc0",
      "avatar_url": "https://avatars.githubusercontent.com/u/12981474?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/trevor-m",
      "html_url": "https://github.com/trevor-m",
      "followers_url": "https://api.github.com/users/trevor-m/followers",
      "following_url": "https://api.github.com/users/trevor-m/following{/other_user}",
      "gists_url": "https://api.github.com/users/trevor-m/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/trevor-m/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/trevor-m/subscriptions",
      "organizations_url": "https://api.github.com/users/trevor-m/orgs",
      "repos_url": "https://api.github.com/users/trevor-m/repos",
      "events_url": "https://api.github.com/users/trevor-m/events{/privacy}",
