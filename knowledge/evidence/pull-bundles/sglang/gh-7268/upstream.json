      "blob_url": "https://github.com/sgl-project/sglang/blob/5d45ea84e35812dccc5ae8677f04bb5329e146dc/python%2Fsglang%2Fsrt%2Flayers%2Fmoe%2Fep_moe%2Flayer.py",
