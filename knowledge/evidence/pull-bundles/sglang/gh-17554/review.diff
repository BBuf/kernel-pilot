+                    )
+                    .abs()
+                    .max()
+                    .item()
+                )
+                max_diff = max(max_diff, diff)
+                all_match = False
+                print(
+                    f"[ERROR] Backend {backend_idx} flashmla_num_splits: MISMATCH! Max diff: {diff}"
+                )
+
+            if dst_ref["flashmla_metadata"] is not None and not torch.equal(
