+    torch.cuda.synchronize()
+
+    # Actual timing
+    torch.cuda.synchronize()
+    loop_start = time.perf_counter()
+    reference_copy_for_loop(data["src"], [dst_ref_0, dst_ref_1, dst_ref_2], bs, max_len)
