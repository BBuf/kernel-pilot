    "title": "[MTP][spec_v2] Fix TRTLLM MLA backend crash in EAGLE draft_extend mode ",
    "user": {
      "login": "YAMY1234",
      "id": 74099316,
      "node_id": "MDQ6VXNlcjc0MDk5MzE2",
      "avatar_url": "https://avatars.githubusercontent.com/u/74099316?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/YAMY1234",
      "html_url": "https://github.com/YAMY1234",
      "followers_url": "https://api.github.com/users/YAMY1234/followers",
      "following_url": "https://api.github.com/users/YAMY1234/following{/other_user}",
      "gists_url": "https://api.github.com/users/YAMY1234/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/YAMY1234/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/YAMY1234/subscriptions",
      "organizations_url": "https://api.github.com/users/YAMY1234/orgs",
      "repos_url": "https://api.github.com/users/YAMY1234/repos",
      "events_url": "https://api.github.com/users/YAMY1234/events{/privacy}",
