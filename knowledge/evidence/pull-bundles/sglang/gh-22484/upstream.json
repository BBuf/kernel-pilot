      "deletions": 3,
      "changes": 12,
      "blob_url": "https://github.com/sgl-project/sglang/blob/87bf145e4841dbdfc2cd221ee12ca5b305c63b27/python%2Fsglang%2Fsrt%2Flayers%2Fquantization%2Ffp8.py",
      "raw_url": "https://github.com/sgl-project/sglang/raw/87bf145e4841dbdfc2cd221ee12ca5b305c63b27/python%2Fsglang%2Fsrt%2Flayers%2Fquantization%2Ffp8.py",
      "contents_url": "https://api.github.com/repos/sgl-project/sglang/contents/python%2Fsglang%2Fsrt%2Flayers%2Fquantization%2Ffp8.py?ref=87bf145e4841dbdfc2cd221ee12ca5b305c63b27",
      "patch": "@@ -531,9 +531,11 @@ def _process_mxfp8_linear_weight_scale(self, layer: Module) -> None:\n             from flashinfer import block_scale_interleave\n \n             scale_u8 = layer.weight_scale_inv.data\n+            # block_scale_interleave may pad and/or reshape scales,\n+            # so store swizzled scales separately to keep weight update working\n             copy_or_rebind_param(\n                 layer,\n-                \"weight_scale_inv\",\n+                \"weight_scale_inv_swizzled\",\n                 block_scale_interleave(scale_u8.contiguous()).contiguous(),\n             )\n         else:\n@@ -688,18 +690,22 @@ def apply(\n             )\n \n         if self.use_mxfp8:\n+            if get_fp8_gemm_runner_backend().is_flashinfer_cutlass():\n+                weight_scale = layer.weight_scale_inv_swizzled\n+            else:\n+                weight_scale = layer.weight_scale_inv\n             if isinstance(x, tuple):\n                 return self.w8a8_mxfp8_linear(\n                     input=x[0],\n                     weight=layer.weight,\n-                    weight_scale=layer.weight_scale_inv,\n+                    weight_scale=weight_scale,\n                     input_scale=x[1],\n                     bias=bias,\n                 )\n             return self.w8a8_mxfp8_linear(\n                 input=x,\n                 weight=layer.weight,\n-                weight_scale=layer.weight_scale_inv,\n+                weight_scale=weight_scale,\n                 input_scale=None,\n                 bias=bias,\n             )"
    }
