      "raw_url": "https://github.com/sgl-project/sglang/raw/b7a831524432842b440c3fa36174d8b18c5f7c58/python%2Fsglang%2Fsrt%2Fmodels%2Fdeepseek_v2.py",
      "contents_url": "https://api.github.com/repos/sgl-project/sglang/contents/python%2Fsglang%2Fsrt%2Fmodels%2Fdeepseek_v2.py?ref=b7a831524432842b440c3fa36174d8b18c5f7c58",
