    "title": "[codex] diffusion: enable group norm silu fuse by default",
    "user": {
      "login": "BBuf",
      "id": 35585791,
      "node_id": "MDQ6VXNlcjM1NTg1Nzkx",
      "avatar_url": "https://avatars.githubusercontent.com/u/35585791?v=4",
