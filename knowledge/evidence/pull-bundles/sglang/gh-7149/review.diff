+        # Create loader instance
+        loader = ModelOptModelLoader(self.load_config)
+
+        # Mock modelopt modules
+        mock_mtq = MagicMock()
+
+        # Configure mtq mock with FP8_DEFAULT_CFG
+        mock_fp8_cfg = MagicMock()
+        mock_mtq.FP8_DEFAULT_CFG = mock_fp8_cfg
