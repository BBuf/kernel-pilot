+        return [
+            PoolTransfer(
+                name=name,
+                host_indices=cat_or_none(t.host_indices for t in ts),
+                device_indices=cat_or_none(t.device_indices for t in ts),
+                keys=[k for t in ts if t.keys for k in t.keys] or None,
+            )
+            for name, ts in grouped.items()
+        ]
