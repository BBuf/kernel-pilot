+            'flashinfer_trtllm' -> 'trtllm'
+            'flashinfer_cutlass' -> 'cutlass'
+            'flashinfer_cudnn' -> 'cudnn'
+        """
+        if self.value.startswith("flashinfer_"):
+            return self.value.removeprefix("flashinfer_")
+        else:
+            return self.value
 
 
