      "raw_url": "https://github.com/sgl-project/sglang/raw/b53363604e74a9382e39e292c1002232b1ca7cff/sgl-kernel%2Fcsrc%2Fgemm%2Fmath.hpp",
      "contents_url": "https://api.github.com/repos/sgl-project/sglang/contents/sgl-kernel%2Fcsrc%2Fgemm%2Fmath.hpp?ref=b53363604e74a9382e39e292c1002232b1ca7cff",
      "patch": "@@ -0,0 +1,28 @@\n+#pragma once\n+\n+#include <climits>\n+#include <iostream>\n+\n+inline constexpr uint32_t next_pow_2(uint32_t const num) {\n+  if (num <= 1) return num;\n+  return 1 << (CHAR_BIT * sizeof(num) - __builtin_clz(num - 1));\n+}\n+\n+template <typename A, typename B>\n+static inline constexpr auto div_ceil(A a, B b) {\n+  return (a + b - 1) / b;\n+}\n+\n+// Round a down to the next multiple of b. The caller is responsible for making\n+// sure that b is non-zero\n+template <typename T>\n+inline constexpr T round_to_previous_multiple_of(T a, T b) {\n+  return a % b == 0 ? a : (a / b) * b;\n+}\n+\n+// Round a up to the next multiple of b. The caller is responsible for making\n+// sure that b is non-zero\n+template <typename T>\n+inline constexpr T round_to_next_multiple_of(T a, T b) {\n+  return a % b == 0 ? a : ((a / b) + 1) * b;\n+}"
