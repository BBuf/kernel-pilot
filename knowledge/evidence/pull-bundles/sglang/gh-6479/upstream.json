      "blob_url": "https://github.com/sgl-project/sglang/blob/b635d4b35208707cc98ed99fda7ded96cdd9fb71/docs%2Freferences%2Fenvironment_variables.md",
      "raw_url": "https://github.com/sgl-project/sglang/raw/b635d4b35208707cc98ed99fda7ded96cdd9fb71/docs%2Freferences%2Fenvironment_variables.md",
      "contents_url": "https://api.github.com/repos/sgl-project/sglang/contents/docs%2Freferences%2Fenvironment_variables.md?ref=b635d4b35208707cc98ed99fda7ded96cdd9fb71",
      "patch": "@@ -57,6 +57,10 @@ SGLang supports various environment variables that can be used to configure its\n | `SGLANG_INT4_WEIGHT` | Enable INT4 weight quantization | `false` |\n | `SGLANG_MOE_PADDING` | Enable MoE padding (sets padding size to 128 if value is `1`, often set to `1` in Docker builds) | `0` |\n | `SGLANG_FORCE_FP8_MARLIN` | Force using FP8 MARLIN kernels even if other FP8 kernels are available | `false` |\n+| `SGLANG_ENABLE_FLASHINFER_GEMM` | Use flashinfer kernels when running blockwise fp8 GEMM on Blackwell GPUs | `false` |\n+| `SGLANG_SUPPORT_CUTLASS_BLOCK_FP8` | Use Cutlass kernels when running blockwise fp8 GEMM on Hopper or Blackwell GPUs | `false` |\n+| `SGLANG_CUTLASS_MOE` | Use Cutlass FP8 MoE kernel on Blackwell GPUs | `false` |\n+\n \n ## Distributed Computing\n "
    },
    {
      "sha": "1f961ed680115427f009cf7e6ca2bc6a3704dda4",
      "filename": "python/sglang/srt/layers/quantization/fp8.py",
      "status": "modified",
      "additions": 2,
      "deletions": 2,
      "changes": 4,
      "blob_url": "https://github.com/sgl-project/sglang/blob/b635d4b35208707cc98ed99fda7ded96cdd9fb71/python%2Fsglang%2Fsrt%2Flayers%2Fquantization%2Ffp8.py",
      "raw_url": "https://github.com/sgl-project/sglang/raw/b635d4b35208707cc98ed99fda7ded96cdd9fb71/python%2Fsglang%2Fsrt%2Flayers%2Fquantization%2Ffp8.py",
      "contents_url": "https://api.github.com/repos/sgl-project/sglang/contents/python%2Fsglang%2Fsrt%2Flayers%2Fquantization%2Ffp8.py?ref=b635d4b35208707cc98ed99fda7ded96cdd9fb71",
      "patch": "@@ -571,7 +571,7 @@ def create_weights(\n             layer.register_parameter(\"w2_weight_scale_inv\", w2_weight_scale)\n             assert self.quant_config.activation_scheme == \"dynamic\"\n             if (\n-                get_bool_env_var(\"CUTLASS_MOE\")\n+                get_bool_env_var(\"SGLANG_CUTLASS_MOE\")\n                 and self.cutlass_fp8_supported\n                 and is_sm100_supported()\n             ):\n@@ -973,7 +973,7 @@ def apply(\n                 return ret\n \n         if (\n-            get_bool_env_var(\"CUTLASS_MOE\")\n+            get_bool_env_var(\"SGLANG_CUTLASS_MOE\")\n             and self.cutlass_fp8_supported\n             and self.block_quant\n             and is_sm100_supported()"
    },
