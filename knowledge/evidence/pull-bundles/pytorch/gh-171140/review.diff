+@contextlib.contextmanager
+def rocm_group_gemm_ck_env(value):
+    var = "ROCM_ALLOW_GROUP_GEMM_CK"
+    old = os.environ.get(var, None)
+    try:
+        if value is None:
+            os.environ.pop(var, None)
+        else:
+            os.environ[var] = value
+        yield
+    finally:
+        if old is None:
+            os.environ.pop(var, None)
+        else:
+            os.environ[var] = old
