    "state": "closed",
    "locked": false,
    "title": "[Graph Partition] Improve support for mutation ops",
    "user": {
      "login": "pytorchbot",
      "id": 21957446,
      "node_id": "MDQ6VXNlcjIxOTU3NDQ2",
      "avatar_url": "https://avatars.githubusercontent.com/u/21957446?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/pytorchbot",
      "html_url": "https://github.com/pytorchbot",
      "followers_url": "https://api.github.com/users/pytorchbot/followers",
      "following_url": "https://api.github.com/users/pytorchbot/following{/other_user}",
      "gists_url": "https://api.github.com/users/pytorchbot/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/pytorchbot/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/pytorchbot/subscriptions",
      "organizations_url": "https://api.github.com/users/pytorchbot/orgs",
      "repos_url": "https://api.github.com/users/pytorchbot/repos",
      "events_url": "https://api.github.com/users/pytorchbot/events{/privacy}",
      "received_events_url": "https://api.github.com/users/pytorchbot/received_events",
