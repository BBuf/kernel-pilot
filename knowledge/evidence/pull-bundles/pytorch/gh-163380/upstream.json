      "blob_url": "https://github.com/pytorch/pytorch/blob/03878933b1c4bbc64a8805bbf245ed9fefbb4df8/test%2Finductor%2Ftest_cudagraph_trees.py",
      "raw_url": "https://github.com/pytorch/pytorch/raw/03878933b1c4bbc64a8805bbf245ed9fefbb4df8/test%2Finductor%2Ftest_cudagraph_trees.py",
      "contents_url": "https://api.github.com/repos/pytorch/pytorch/contents/test%2Finductor%2Ftest_cudagraph_trees.py?ref=03878933b1c4bbc64a8805bbf245ed9fefbb4df8",
      "patch": "@@ -3233,6 +3233,60 @@ def fn(x):\n             # splitting on 1 custom gives 2 cudagraphs\n             self.assertEqual(self.get_manager().new_graph_id().id, 2)\n \n+        @config.patch(implicit_fallbacks=True)\n+        @torch._inductor.config.patch(\"graph_partition\", True)\n+        def test_graph_partition_custom_op_mutation_late_free(self):\n+            @torch.library.custom_op(\n+                \"mylib::op1\",\n+                mutates_args=[\"x\"],\n+                schema=\"(Tensor(a!)?  x) -> (Tensor, Tensor)\",\n+                device_types=\"cuda\",\n+            )\n+            def op1(x) -> tuple[torch.Tensor, torch.Tensor]:\n+                x = x + 1\n+                return (x + 1, x + 2)\n+\n+            @op1.register_fake\n+            def _(x) -> tuple[torch.Tensor, torch.Tensor]:\n+                return (torch.empty_like(x), torch.empty_like(x))\n+\n+            @torch.library.custom_op(\n+                \"mylib::cg_unsafe_op\",\n+                mutates_args=[],\n+                schema=\"(Tensor x, Tensor y, Tensor x1, Tensor y1) -> Tensor\",\n+                device_types=\"cuda\",\n+                tags=(torch._C.Tag.cudagraph_unsafe,),\n+            )\n+            def cg_unsafe_op(x0, x1, y0, y1) -> torch.Tensor:\n+                return x0 + x1 + y0 + y1\n+\n+            @cg_unsafe_op.register_fake\n+            def _(x0, x1, y0, y1) -> torch.Tensor:\n+                return torch.empty_like(x0)\n+\n+            def f(x):\n+                x = x + 1\n+                x = op1(x)\n+                x0, x1 = x[0], x[1]\n+                y0 = x0 + 1\n+                y1 = x1 + 1\n+                y = cg_unsafe_op(x0, x1, y0, y1)\n+                z = y + x0 + x1\n+                z0, z1 = op1(z)\n+                z2 = z0 + z1\n+                res = cg_unsafe_op(z2, z2, y, y)\n+                return res\n+\n+            x = torch.randn(2, 2, device=\"cuda\")\n+            x_cloned = x.clone()\n+            eager_out = f(x)\n+\n+            f_compiled = torch.compile(f, mode=\"reduce-overhead\")\n+\n+            for _ in range(5):\n+                compiled_out = f_compiled(x_cloned)\n+                self.assertEqual(eager_out, compiled_out)\n+\n         @config.patch(implicit_fallbacks=True)\n         @torch._inductor.config.patch(\"graph_partition\", True)\n         def test_graph_partition_custom_op_dynamoc_shapes(self):"
    },
