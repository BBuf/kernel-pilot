      "subscriptions_url": "https://api.github.com/users/emre570/subscriptions",
      "organizations_url": "https://api.github.com/users/emre570/orgs",
      "repos_url": "https://api.github.com/users/emre570/repos",
      "events_url": "https://api.github.com/users/emre570/events{/privacy}",
