    "title": "Add Snake activation functor for EVT",
    "user": {
      "login": "emre570",
      "id": 70805503,
      "node_id": "MDQ6VXNlcjcwODA1NTAz",
      "avatar_url": "https://avatars.githubusercontent.com/u/70805503?v=4",
