+#define CUDA_CHECK(status)                                                                 \
+    {                                                                                      \
+        cudaError_t error = status;                                                       \
+        if (error != cudaSuccess) {                                                       \
+            std::cerr << "CUDA error: " << cudaGetErrorString(error) << " at " <<        \
+                __FILE__ << ":" << __LINE__ << std::endl;                                 \
+            exit(EXIT_FAILURE);                                                           \
+        }                                                                                 \
+    }
