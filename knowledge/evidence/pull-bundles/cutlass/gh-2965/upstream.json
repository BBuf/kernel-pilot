    "state": "closed",
    "locked": false,
    "title": "[Bug Fix]Set NumSplitsM to 1 when TileShapeM < 128 in sm90 fp8 blockwise scaling CollectiveMma",
    "user": {
      "login": "HydraQYH",
      "id": 45795032,
      "node_id": "MDQ6VXNlcjQ1Nzk1MDMy",
      "avatar_url": "https://avatars.githubusercontent.com/u/45795032?v=4",
