    "title": "[EVT] Add support for Row/Col broadcast PtrArray",
    "user": {
      "login": "jwfromm",
      "id": 9874242,
      "node_id": "MDQ6VXNlcjk4NzQyNDI=",
      "avatar_url": "https://avatars.githubusercontent.com/u/9874242?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/jwfromm",
      "html_url": "https://github.com/jwfromm",
      "followers_url": "https://api.github.com/users/jwfromm/followers",
