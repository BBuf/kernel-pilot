      "starred_url": "https://api.github.com/users/Xinyu302/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Xinyu302/subscriptions",
      "organizations_url": "https://api.github.com/users/Xinyu302/orgs",
      "repos_url": "https://api.github.com/users/Xinyu302/repos",
