+@cute.jit
+def score_mod_global_q_and_kv_bias(
+    tSrS_ssa, b_idx, h_idx, q_idx, kv_idx, seqlen_info, aux_tensors
+):
+    """Both q and kv global indices."""
+    offset_q = seqlen_info.offset_q
+    q_idx_global = q_idx + offset_q
