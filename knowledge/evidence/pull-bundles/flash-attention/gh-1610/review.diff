+                dk,
+                dv,
+            ) = torch.autograd.grad(out, (q, k, v), g)
+            dq_equal = torch.allclose(dq, dq0, atol=dq_atol)
+            if not dq_equal:
+                print(f"Iter {i}, {dq_atol = }, dQ max diff: {(dq - dq0).abs().max().item()}")
+            assert torch.equal(dv, dv0)
+            assert torch.equal(dk, dk0)
+            assert dq_equal
