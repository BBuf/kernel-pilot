-    tokens = corpus.split()
-    vocab = sorted(set(tokens))
-    word2idx = {word: idx for idx, word in enumerate(vocab)}
-    token_ids = [word2idx[word] for word in tokens]
-    
-    num_workers = 2
-    if is_varlen:
-        # VARIABLE LENGTH: create sequences of different lengths
