+            dk,
+            dv,  # output tensors
+            q_ptr_adj,
+            k,
+            v,
+            do_ptr_adj,
+            dq_ptr_adj,
+            m_ptr_adj,
+            delta_ptr_adj,
+            sm_scale,  # input tensors
+            stride_q_m,
+            stride_q_k,  # strides for q
+            stride_dq_m,
+            stride_dq_k,  # strides for q
+            stride_do_m,
+            stride_do_k,  # strides for o
+            stride_dropout_m,
+            stride_dropout_n,  # strides for dropout
+            stride_delta_m,
+            dropout_p,
+            philox_seed,
+            batch_philox_offset,
+            dropout_offset,  #
+            seqlen_q,
+            seqlen_k,  # max sequence length for q and k
+            start_n,
+            start_m,
+            num_steps,  # iteration numbers
+            descale_q,
+            descale_k,
+            descale_v,
