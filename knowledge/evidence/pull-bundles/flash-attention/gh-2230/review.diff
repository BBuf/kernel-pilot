-        offs_seq = blk_idx * BLOCK_SIZE + tl.arange(0, BLOCK_SIZE)
-        offs_dim = tl.arange(0, HEAD_DIM)
-
-        mask_seq = offs_seq[:, None] < seqlen
-        if ACTUAL_HEAD_DIM != HEAD_DIM:
