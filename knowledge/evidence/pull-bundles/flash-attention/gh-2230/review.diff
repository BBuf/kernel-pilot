-            mask_seq = mask_seq & mask_dim
-
-        addr = (
-            b_id * stride_batch
-            + h_id * stride_head
-            + seq_start * stride_seq
-            + offs_seq[:, None] * stride_seq
-            + offs_dim[None, :] * stride_dim
