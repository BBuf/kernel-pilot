-            + rk_half[None, None, :] * stride_x_headdim
-        )
-        OUT = OUT + (
-            rh[:, None, None] * stride_out_nheads
-            + rm[None, :, None] * stride_out_seqlen
-            + rk_half[None, None, :] * stride_out_headdim
