-
-        addr_out = (
-            b_id * stride_out_batch
-            + h_id * stride_out_head
-            + seq_start * stride_out_seq
-            + offs_seq[:, None] * stride_out_seq
-            + offs_dim[None, :] * stride_out_dim
-        )
-        tl.store(X_fp8 + addr_out, x_fp8_block, mask=mask_seq)
