+    block_sparse_mask_bwd = BlockSparseTensorsTorch(
+        mask_block_cnt=q_mask_cnt, mask_block_idx=q_mask_idx,
+        full_block_cnt=full_q_cnt, full_block_idx=full_q_idx,
