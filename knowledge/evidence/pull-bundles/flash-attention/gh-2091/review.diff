+
+    from flash_attn.cute.mask_definitions import get_mask_pair
+    mask_mod_cute, mask_mod_flex = get_mask_pair("document", seqlen_q=seqlen_q, seqlen_k=seqlen_k)
+
+    original_flex_mask = mask_mod_flex
