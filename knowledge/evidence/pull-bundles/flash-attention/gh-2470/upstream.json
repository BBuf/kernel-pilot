      "starred_url": "https://api.github.com/users/Johnsonms/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Johnsonms/subscriptions",
      "organizations_url": "https://api.github.com/users/Johnsonms/orgs",
