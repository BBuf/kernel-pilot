    "title": "Allow compact block sparse index tensors",
    "user": {
      "login": "jduprat",
      "id": 865537,
      "node_id": "MDQ6VXNlcjg2NTUzNw==",
      "avatar_url": "https://avatars.githubusercontent.com/u/865537?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/jduprat",
      "html_url": "https://github.com/jduprat",
      "followers_url": "https://api.github.com/users/jduprat/followers",
