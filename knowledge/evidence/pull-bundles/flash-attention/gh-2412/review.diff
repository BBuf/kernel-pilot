+        k_layout = cute.make_layout(
+            (s_k_total, d, ((h_r, h_k), b)),
+            stride=(d64 * h_k64, 1, ((0, d64), stride_b_kv)),
+        )
+        k = cute.make_tensor(k_tensor.iterator, k_layout)
