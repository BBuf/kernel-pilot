+        print("v:", v, v.shape)
+        print("sm_scale:", sm_scale)
+        print("causal:", causal)
+        print("cu_seqlens_q:", cu_seqlens_q)
+        print("cu_seqlens_k:", cu_seqlens_k)
+        print("max_seqlen_q:", max_seqlen_q)
+        print("max_seqlen_k:", max_seqlen_k)
+        print("use_exp2:", use_exp2)
+
+     # compute reference
+    if layout == "thd":
+        (
+            o_ref,
