+        print("tri_dv:", tri_dv)
+        print("ref_dk:", ref_dk)
+        print("tri_dk:", tri_dk)
+        print("ref_dq:", ref_dq)
+        print("tri_dq:", tri_dq)
+
+    torch.testing.assert_close(ref_dv, tri_dv, atol=ATOL, rtol=RTOL)
+    torch.testing.assert_close(ref_dk, tri_dk, atol=ATOL, rtol=RTOL)
+    torch.testing.assert_close(ref_dq, tri_dq, atol=ATOL, rtol=RTOL)
