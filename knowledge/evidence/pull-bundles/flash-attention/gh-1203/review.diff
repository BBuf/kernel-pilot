+import torch
+import math
+from .utils import DEBUG
+
+def attention_backward_core_ref_impl(
+    do, q, k, v, o, softmax_lse, sm_scale, causal, use_exp2
+):
+    if DEBUG:
+        print()
+        print("attention_backward_core_ref_impl")
