+    DEBUG_INPUT = False
+
+    # seqlens
+    seqlen_q = N_CTX_Q
+    seqlen_k = N_CTX_K
+
+    # setup up metadata
+    if DEBUG_INPUT:
+        sm_scale = 1
+    else:
+        sm_scale = D_HEAD**-0.5
