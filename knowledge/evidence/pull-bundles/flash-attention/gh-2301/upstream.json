    "title": "Fix GQA crash in cute FLASH backend: init load_Q before conditional",
    "user": {
      "login": "platers",
      "id": 10098493,
      "node_id": "MDQ6VXNlcjEwMDk4NDkz",
      "avatar_url": "https://avatars.githubusercontent.com/u/10098493?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/platers",
      "html_url": "https://github.com/platers",
